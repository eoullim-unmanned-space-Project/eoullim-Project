<!--                <button type="submit" class="btn-send" id="btn-send">보내기</button>-->
<!--            </form>-->
<!--        </div>-->
        <div class="fab-wrapper" id="fabContainer">
            <div class="fab-menu">
                <div class="fab-item">
                    <span class="fab-tooltip">문의하기</span>
                    <button class="sub-btn contact" onclick="location.href='/qna/form'">
                        <i class="fas fa-envelope"></i> <span class="emoji">📧</span>
                    </button>
                </div>
                <div class="fab-item">
                    <span class="fab-tooltip">오늘의 운세</span>
                    <button class="sub-btn fortune" onclick="openFortune()">
                        <span class="emoji">🔮</span>
                    </button>
                </div>
                <div class="fab-item">
                    <span class="fab-tooltip">1:1 채팅</span>
                    <button class="sub-btn chat" onclick="openChat()">
                        <span class="emoji">💬</span>
                    </button>
                </div>
            </div>

            <button class="main-btn" id="mainFab">
                <span class="plus-icon">+</span>
            </button>
        </div>
    </section>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const fabWrapper = document.getElementById('fabContainer');
        const mainBtn = document.getElementById('mainFab');

        mainBtn.addEventListener('click', function(e) {

            if (mainBtn.contains(e.target)) {
                fabWrapper.classList.toggle('active');
            } else if (!fabWrapper.contains(e.target)) {
                fabWrapper.classList.remove('active');
            }

        });


    })

</script>


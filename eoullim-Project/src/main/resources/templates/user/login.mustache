{{> layout/header}}
<link rel="stylesheet" href="/templates/user/css/loginStyle.css">

<body>
<main>
    <div class="container">
        <div class="inner-wrapper">
            <div class="inner-left">
                <img src="/templates/user/img/login.png" alt="">
            </div>
            <div class="inner-right">
                <!-- 추후 작성 -->
                <form action="">
                    <div>
                        <label >아이디</label>
                        <input type="text" id="username">
                    </div>
                    <div>
                        <label>비밀번호</label>
                        <input type="password" id="password">
                    </div>
                    <div>
                        <button id="signupBtn">로그인</button>
                    </div>
                    <div class="register-box">
                        <a href="#">아이디 찾기</a> <span>|</span>
                        <a href="#">회원가입</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
</body>
{{> layout/footer}}
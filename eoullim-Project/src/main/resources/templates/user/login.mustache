{{> layout/header}}
<link rel="stylesheet" href="/templates/user/css/loginStyle.css">

<body>
<main>
    <div class="container">
        <div class="inner-wrapper">
            <div class="inner-left">
                <img src="../register/img/login.png" alt="">
            </div>
            <div class="inner-right">
                <form>
                    <div class="form-group">
                        <label>아이디</label>
                        <input type="text" placeholder="아이디를 입력해주세요">
                    </div>

                    <div class="form-group">
                        <label>비밀번호</label>
                        <input type="password" placeholder="비밀번호를 입력해주세요">
                    </div>
                    <button type="button" id="signupBtn">로그인</button>
                    <div class="social-login">
                        <button type="button" class="kakao-login">
                            <img src="./img/kakao.png"> 카카오로 로그인
                        </button>
                        <button type="button" class="naver-login">
                            <img src="./img/naver.png"> 네이버로 로그인
                        </button>
                    </div>
                    <div class="register-box">
                        <a href="#">아이디 찾기</a> | <a href="./signUp.mustache">회원가입</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
</body>
{{> layout/footer}}
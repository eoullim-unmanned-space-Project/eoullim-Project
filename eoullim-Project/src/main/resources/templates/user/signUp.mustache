<link rel="stylesheet" href="/templates/layout/css/header.css">
<link rel="stylesheet" href="/templates/user/css/register.css">
{{> layout/header}}
<body>
<main>
    <div class="container">
        <div class="inner-wrapper">
            <div class="inner-left">
                <img src="./img/login.png" alt="">
            </div>
            <div class="inner-right">
                <!-- 추후 form 액션 작성 -->
                <form action="">
                    <div class="label-item">
                        <label>아이디</label>
                        <input type="text" id="loginId" placeholder="아이디 입력(6~20자)">
                    </div>
                    <div class="label-item">
                        <label>비밀번호</label>
                        <input type="password" id="password" placeholder="비밀번호 입력(문자, 숫자, 특수문자 포함 8~20자)">
                    </div>
                    <div class="label-item">
                        <label>비밀번호 확인</label>
                        <input type="password" id="passwordCheck" placeholder="비밀번호 재입력">
                    </div>
                    <div class="label-item">
                        <label>이름</label>
                        <input type="text" id="name" placeholder="이름을 입력해주세요">
                    </div>
                    <div class="label-item">
                        <label>이메일</label>
                        <input type="email" id="email" placeholder="이메일 주소를 입력해주세요 '@' 포함">
                    </div>
                    <div class="label-item">
                        <label>휴대폰 번호</label>
                        <input type="text" id="phone" placeholder="휴대폰 번호 입력 ('-' 제외 11자리 입력)">
                    </div>
                    <div>
                        <button id="signupBtn">회원가입</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
</body>
{{> layout/footer}}
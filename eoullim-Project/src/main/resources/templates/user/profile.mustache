<link rel="stylesheet" href="/css/user/profile.css">
<link rel="stylesheet" href="/css/layout/header.css"/>
{{> layout/header}}
<body>
<div class="mypage-container">

    {{> layout/sideBar}}

    <!-- 오른쪽 메인 영역 -->
    <main class="mypage-main">
        <div class="profile-box">
            <h2>회원정보 관리</h2>

            <!-- 프로필 이미지 -->
            <div class="profile-image">
                <label for="profileUpload" class="profile-label">
                    <img id="profilePreview" src="{{user.profileImage}}">
                    <span class="edit-overlay">변경</span>
                </label>
                <input
                        type="file"
                        id="profileUpload"
                        name="profileImage"
                        accept="image/*"
                        hidden
                />
            </div>

            <p class="username"><span>{{user.name}}</span>님</p>
            {{^isKakaoUser}}
                <div class="info-row">
                    <label class="label">휴대전화</label>
                    <input
                            type="tel"
                            name="phone"
                            class="value-input"
                            value="{{phone}}"
                            readonly
                    />
                </div>

                <div class="info-row">
                    <label class="label">이메일(ID)</label>
                    <input
                            type="email"
                            name="email"
                            class="value-input"
                            value="{{user.email}}"
                            readonly
                    />
                </div>

                <div class="info-row">
                    <label class="label">가입일</label>
                    <input
                            type="email"
                            name="email"
                            class="value-input"
                            value="{{user.createdAt}}"
                            readonly
                    />
                </div>

                <div class="btn-wrapper">
                    <form id="withdrawForm">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
<!--                        <label class="label">회원탈퇴</label>-->
                        <button type="submit" class="edit-btn">
                            탈퇴하기
                        </button>
                    </form>
                </div>
            {{/isKakaoUser}}
            {{#sessionUser.canUpdateProfile}}
                {{^isKakaoUser}}

                    <!--                    <form action="/user/profile/edit" method="get">-->
                    <!--                        <button type="submit" class="edit-btn">-->
                    <!--                            회원정보 수정-->
                    <!--                        </button>-->
                    <!--                    </form>-->
                {{/isKakaoUser}}
            {{/sessionUser.canUpdateProfile}}


            {{#isKakaoUser}}
                <div class="kakao-status-wrapper">
                    <span class="kakao-label">카카오 로그인</span>
                    <div class="static-switch">
                        <div class="static-circle"></div>
                    </div>
                </div>
            {{/isKakaoUser}}
        </div>
    </main>
</div>

<script>
    document.getElementById("withdrawForm").addEventListener("submit", async (e) => {
        e.preventDefault();

        if (!confirm("정말 탈퇴하시겠습니까?")) return;

        const csrfToken = document.querySelector('input[name="_csrf"]').value;

        try {
            const res = await fetch("/api/user/withdraw", {
                method: "POST",
                headers: {
                    "X-XSRF-TOKEN": csrfToken
                },
                credentials: "include"
            });

            if (res.ok) {
                alert("회원 탈퇴가 완료되었습니다.");
                window.location.href = "/auth/login"; // JS에서 로그인 페이지로 이동
            } else {
                const text = await res.text();
                alert("탈퇴 실패: " + text);
            }
        } catch (err) {
            console.error(err);
            alert("오류가 발생했습니다.");
        }
    });
</script>

</body>
{{> layout/footer}}
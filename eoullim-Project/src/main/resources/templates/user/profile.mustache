<link rel="stylesheet" href="/css/user/profile.css">
<link rel="stylesheet" href="/css/layout/header.css"/>
{{> layout/header}}
<body>
<div class="mypage-container">
    <!-- 왼쪽 영역 -->
    <aside class="mypage-sidebar">
        <h2>마이페이지</h2>
        <p class="welcome"><span>{{user.name}}</span>님, 안녕하세요</p>
        <hr/>

        <section class="menu-section">
            <h3>예약정보</h3>
            <ul>
                <li><span>예약내역</span></li>
            </ul>
        </section>
        <hr/>
        <section class="menu-section">
            <h3>활동정보</h3>
            <ul>
                <li><span>리뷰</span></li>
                <li><span>Q&A</span></li>
            </ul>
        </section>
        <hr/>
    </aside>

    <!-- 오른쪽 메인 영역 -->
    <main class="mypage-main">
        <div class="profile-box">
            <h2>회원정보 관리</h2>

            <!--            <form action="/user/profile" method="post" enctype="multipart/form-data">-->
            <!-- 프로필 이미지 -->
            <div class="profile-image">
                <label for="profileUpload" class="profile-label">
                    <img id="profilePreview" src="{{user.profileImageUrl}}">
                    <span class="edit-overlay">변경</span>
                </label>
                <input
                        type="file"
                        id="profileUpload"
                        name="profileImage"
                        accept="image/*"
                        hidden
                />
            </div>

            <p class="username"><span>{{user.name}}</span>님</p>

            <div class="info-row">
                <label class="label">휴대전화</label>
                <input
                        type="tel"
                        name="phone"
                        class="value-input"
                        value="{{#user}}{{phone}}{{/user}}"
                />
            </div>

            <div class="info-row">
                <label class="label">이메일(ID)</label>
                <input
                        type="email"
                        name="email"
                        class="value-input"
                        value="{{user.email}}"
                        readonly
                />
            </div>

            <div class="info-row">
                <label class="label">가입일</label>
                <input
                        type="email"
                        name="email"
                        class="value-input"
                        value="{{user.createdAt}}"
                        readonly
                />
            </div>

            <form action="/user/profile/edit" method="get">
                <button type="submit" class="edit-btn">
                    회원정보 수정
                </button>
            </form>
            <!--            </form>-->
        </div>
    </main>
</div>
</body>
{{> layout/footer}}
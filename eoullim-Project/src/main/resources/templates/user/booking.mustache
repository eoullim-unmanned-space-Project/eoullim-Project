<link rel="stylesheet" href="/css/layout/header.css">
<link rel="stylesheet" href="/css/user/booking.css">
{{> layout/header}}
<body>
<div class="mypage-container">
    {{> layout/sideBar}}
    <!-- 메인 -->
    <section class="mypage-main">

        <div class="booking-search">
            <h2>예약 조회</h2>
            <div class="booking-search-row">
                <input class="booking-input" type="text" placeholder="예약 코드를 입력해 주세요">
                <button class="booking-search-btn">조회</button>
            </div>
        </div>
        <div class="booking-filter">
            <button class="booking-filter-btn" >전체보기</button>
            <button class="booking-filter-btn" data-status="PENDING">대기중</button>
            <button class="booking-filter-btn" data-status="CONFIRMED">예약완료</button>
            <button class="booking-filter-btn" data-status="CANCELED">예약취소</button>
            <button class="booking-filter-btn" data-status="REFUNDED">환불완료</button>
        </div>

        <div class="booking-list" id="booking-list">

        </div>
    </section>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const bookingBtn = document.querySelector('.booking-search-btn');
        const bookingInput = document.querySelector('.booking-input');
        const filterRoot = document.querySelectorAll('.booking-filter');

        async function sendSearch() {
            let bookingCode = bookingInput.value.trim() || '';

            const activeBtn = document.querySelector('.booking-filter-btn.active');
            let status = (activeBtn && activeBtn.dataset.status) ? activeBtn.dataset.status : '';

            try {
                 const response = await fetch(`/api/user/search?code=${bookingCode}&status=${status}`, {
                    method: "GET",
                    headers: {
                        "Content-Type" : "application/json"
                    }
                });

                if(!response.ok) {
                    throw new Error(`서버 응답 에러: ${response.status}`);
                }

                const data = await response.json();

                displayBookings(data);

            } catch(error) {
                console.error(error.message);
            }
        }

          filterRoot.forEach(filter => {

            const filterBtn = filter.querySelectorAll('.booking-filter-btn');

            filterBtn.forEach(button => {
                button.addEventListener('click', () => {
                    filterBtn.forEach(b => b.classList.remove('active'));
                    button.classList.add('active');
                    status = button.dataset.status;
                    sendSearch();
                })
            })
        })

        bookingBtn.addEventListener('click', sendSearch);

        bookingInput.addEventListener('keyup', (event) => {
            if (event.key === 'Enter') {
                sendSearch();
            }
        });

        sendSearch()

        function displayBookings(data) {
            const bookingList = document.getElementById('booking-list');

            bookingList.innerHTML = ''

            if(!data || data.length === 0) {
                bookingList.innerHTML = `
                <div class="empty-card">
                    <p class="empty-title">📅 예약 내역이 존재하지 않습니다</p>
                    <p class="empty-desc">
                        아직 예약한 내역이 없어요.<br>
                        새로운 공간을 예약해 보세요!
                    </p>
                </div>
                `;
            }

            data.forEach(booking => {
                const card = document.createElement('div');
                card.className = 'booking-card';

                card.innerHTML = `
                <div class="booking-thumb">
                    <img src="/images/room-sample.jpg" alt="스터디룸 이미지">
                </div>
                <div class="booking-content">
                    <div class="booking-card-header">
                        <span class="booking-place">🚩${booking.roomName}</span>
                        <span class="booking-status confirmed">${booking.status}</span>
                    </div>

                    <div class="booking-card-body">
                        <div class="booking-info-row">
                            <span class="label">예약 코드</span>
                            <span class="booking-code">${booking.bookingCode}</span>
                        </div>

                        <div class="booking-info-row">
                            <span class="label">이용 시간</span>
                            <span>${booking.displayTime}</span>
                        </div>

                        <div class="booking-info-row price">
                            <span class="label">결제 금액</span>
                            <span>${Number(booking.amount).toLocaleString()}원</span>
                        </div>
                    </div>

                    <div class="booking-card-footer">
                        <button class="booking-detail-btn" data-code="${booking.bookingCode}">상세보기</button>
                    </div>
                </div>`;

                bookingList.appendChild(card);
                });

                const detailBtns = document.querySelectorAll('.booking-detail-btn');
                detailBtns.forEach(btn => {
                    btn.addEventListener('click', async () => {

                    const bookingCode = btn.dataset.code;

                    try {
                        const response = await fetch(`/api/user/payment?code=${bookingCode}`);

                        const data = await response.json();

                        modal(data);

                    } catch(error) {
                        console.error("데이터를 불러오는 중 에러 발생:", error);
                        alert("결제 내역을 불러오는데 실패했습니다.\n나중에 다시 시도해주세요.");
                    }

                  function modal(data) {

                    const refundStatus = data ? data.refundStatus : null;
                    const isPending = refundStatus === 'REQUESTED';

                    const container = document.createElement('div');
                    container.className = 'modal-overlay';

                    container.innerHTML = `
                        <div class="receipt-card">
                            <button class="btn-close" type="button">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 6L6 18M6 6l12 12"/>
                                </svg>
                            </button>
                            <header class="receipt-header">
                                <div style="background: #e8f3ff; width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3182f6" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </div>
                                <h2 class="status-text">${data.displayStatus}</h2>
                                <p class="date" id="r-paidAt">2026년 1월 8일 21:30</p>
                            </header>
                            <section class="info-box">
                                <div class="info-row">
                                    <span class="label">이용자 이름</span>
                                    <span class="value" id="r-name">${data.name}</span>
                                </div>
                                <div class="info-row">
                                    <span class="label">이용 공간</span>
                                    <span class="value" id="r-roomName">${data.roomName}</span>
                                </div>
                                <div class="info-row">
                                    <span class="label">이용 시간</span>
                                    <span class="value" id="r-time">${data.displayTime}</span>
                                </div>
                                <div class="info-row">
                                    <span class="label">인원 수</span>
                                    <span class="value" id="r-qty">${data.qty}명</span>
                                </div>
                                <div class="info-row">
                                    <span class="label">결제 방법</span>
                                    <span class="value" id="r-method">${data.paymentMethod}</span>
                                </div>
                                <div class="info-row">
                                    <span class="label">결제 상태</span>
                                    <span class="value" id="r-status" style="color: #3182f6;">${data.displayStatus}</span>
                                </div>
                            </section>
                            <div class="price-row">
                                <span class="total-label">총 결제금액</span>
                                <span class="total-amount" id="r-amount">${Number(data.amount).toLocaleString()}원</span>
                            </div>
                            <div id="refund-section">
                               ${isPending
                                    ? `<button class="btn-refund" disabled style="background:#ccc; cursor:not-allowed; width:100%; padding:12px; border:none; border-radius:8px; color:white;">
                                     환불 대기중
                                   </button>`
                                        : `<button class="btn-refund" type="button" data-paymentkey="${data.paymentKey}">
                                     환불 요청하기
                                   </button>`
                                }
                            </div>
                            <span class="order-id">주문번호: <span id="r-bookingCode">${data.bookingCode}</span></span>
                        </div>`;

                        document.body.appendChild(container);

                        const statusText = container.querySelector('.status-text');
                        const statusElement = container.querySelector('#r-status');
                        const totalElement = container.querySelector('#r-amount');
                        const refundSection = container.querySelector("#refund-section");
                        const refundBtn = container.querySelector('.btn-refund');
                        const iconWrapper = container.querySelector('.receipt-header div');
                        const iconCheck = iconWrapper.querySelector('polyline');

                        if (status === '결제준비') {
                            statusText.style.color = "#6B7684";
                            statusElement.style.color = "#6B7684";
                            totalElement.style.color = "#6B7684";
                            iconWrapper.style.backgroundColor = "#F2F4F6";
                            iconCheck.setAttribute('stroke', "#6B7684");
                            refundBtn.style.display = 'none';

                        } else if (status === '환불완료') {
                            statusText.style.color = "#19B36E";
                            statusElement.style.color = "#19B36E";
                            totalElement.style.color = "#19B36E";
                            iconWrapper.style.backgroundColor = "#E7F9F0";
                            iconCheck.setAttribute('stroke', "#19B36E");
                            refundBtn.style.display = 'none';

                        } else if (status === '결제취소' || status === '결제실패') {
                            statusText.style.color = "#F04452";
                            statusElement.style.color = "#F04452";
                            totalElement.style.color = "#F04452";
                            iconWrapper.style.backgroundColor = "#FEEFEF";
                            iconCheck.setAttribute('stroke', "#F04452");
                            refundBtn.style.display = 'none';

                        } else {
                            statusText.style.color = "#3182F6";
                            statusElement.style.color = "#3182F6";
                            totalElement.style.color = "#3182F6";
                            iconWrapper.style.backgroundColor = "#E8F3FF";
                            iconCheck.setAttribute('stroke', "#3182F6");
                        }

                        const closeBtn = container.querySelector('.btn-close');

                        closeBtn.addEventListener('click', () => {
                            container.remove();
                        });

                        container.addEventListener('click', (e) => {
                             if(e.target === container) {
                                container.remove();
                             }
                        });

                       refundSection.onclick = async (e) => {

                          if (e.target.classList.contains("btn-refund")) {
                              const paymentKey = e.target.dataset.paymentkey;

                              refundSection.innerHTML = `
                                <div style="margin-top: 15px; border-top: 1px dashed #ddd; padding-top: 15px;">
                                    <textarea id="refund-reason" placeholder="환불 사유를 적어주세요" style="
                                        width: 100%; height: 70px; padding: 10px; border: 1px solid #eee;
                                        border-radius: 8px; background: #fafafa; resize: none; margin-bottom: 8px;
                                    "></textarea>
                                    <div style="display: flex; gap: 6px;">
                                        <button type="button" id="submit-refund" data-paymentkey="${paymentKey}" style="flex: 2; padding: 10px; background: #3182f6; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: bold;">확인 전송</button>
                                        <button type="button" id="cancel-refund" data-paymentkey="${paymentKey}" style="flex: 1; padding: 10px; background: #eee; border: none; border-radius: 6px; cursor: pointer;">취소</button>
                                    </div>
                                </div>`;
                              }

                               if(e.target.id === 'submit-refund') {
                                   const reason = document.getElementById('refund-reason').value;
                                   const paymentKey = e.target.dataset.paymentkey;

                                   if (!reason.trim()) {
                                       alert("환불 사유를 작성해주세요.");
                                   }

                                   try {
                                       const response = await fetch("/api/user/refund", {
                                           method: "POST",
                                           headers: {
                                               "Content-Type" : "application/json"
                                           },
                                           body: JSON.stringify({
                                               paymentKey: paymentKey,
                                               reason: reason
                                           })
                                       })

                                       if (!response.ok) {
                                           alert("환불 실패")
                                       }

                                       if (response.ok) {
                                           const result = await response.json();
                                           alert(result.message);

                                           console.log('서버 응답:', data);

                                           refundSection.innerHTML =
                                                   `<button class="btn-refund" disabled style="background:#ccc; cursor:not-allowed; width:100%; padding:12px; border:none; border-radius:8px; color:white;">
                                                        환불 대기중
                                                    </button>
                                                    `;

                                           await sendSearch();

                                       } else {
                                           alert("환불 처리에 실패했습니다.");
                                       }
                                   } catch (error) {
                                       console.error("환불 요청에 에러가 발생했습니다.", error);

                                   }
                               }

                              if (e.target.id === "cancel-refund") {
                                  const paymentKey = e.target.dataset.paymentkey;
                                  refundSection.innerHTML = `
                                    <button class="btn-refund" type="button" data-paymentkey="${paymentKey}">
                                        환불 요청하기
                                    </button>`;
                              }
                      };
                    } // MODAL End point
                });
            });
        }
    }) // DOM End point
</script>

</body>
{{> layout/footer}}

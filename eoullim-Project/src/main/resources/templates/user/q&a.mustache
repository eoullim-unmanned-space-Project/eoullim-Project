<link rel="stylesheet" href="/css/layout/header.css">
<link rel="stylesheet" href="/css/user/q&a.css">
{{> layout/header}}
<main>
    <div class="mypage-container">
        <!-- 왼쪽 사이드바 -->
        <aside class="mypage-sidebar">
            <h2>마이페이지</h2>
            <p class="welcome"><span>홍길동</span>님, 안녕하세요</p>
            <hr />

            <section class="menu-section">
                <h3>예약정보</h3>
                <ul>
                    <li><span>예약내역</span></li>
                </ul>
            </section>
            <hr />

            <section class="menu-section">
                <h3>활동정보</h3>
                <ul>
                    <li><span>리뷰</span></li>
                    <li><span>Q</span>&A</li>
                </ul>
            </section>
            <hr />
        </aside>
        <!-- 오른쪽 메인 -->
        <main class="mypage-main">
            <h2>Q&A</h2>
            <!-- Q&A 작성 폼 -->
            <div class="qna-form" style="margin-bottom:32px;">
                <h3>질문 작성</h3>
                <form action="/mypage/qna" method="post">
                    <div class="info-row">
                        <label class="label">제목</label>
                        <input type="text" name="title" placeholder="질문 제목을 입력하세요"
                               style="flex:1; padding:8px; border:1px solid #d1d5db; border-radius:6px;" required />
                    </div>
                    <div class="info-row">
                        <label class="label">내용</label>
                        <textarea name="content" placeholder="질문 내용을 입력하세요"
                                  style="flex:1; padding:8px; border:1px solid #d1d5db; border-radius:6px; min-height:80px;" required></textarea>
                    </div>
                    <button type="submit" class="edit-btn">작성</button>
                </form>
            </div>
            <!-- Q&A 리스트 -->
            <div class="qna-box">
                <h3>내 질문 목록</h3>
                <div class="qna-item">
                    <div class="qna-question"><span>Q.</span> 예약 취소는 어떻게 하나요?</div>
                    <div class="qna-answer">마이페이지 → 예약내역에서 취소 가능합니다.</div>
                </div>
                <div class="qna-item">
                    <div class="qna-question"><span>Q.</span> 회원정보 수정 후 변경 사항은 언제 적용되나요?</div>
                    <div class="qna-answer">즉시 적용됩니다.</div>
                </div>
                <div class="qna-item">
                    <div class="qna-question"><span>Q.</span> 비밀번호를 변경하고 싶어요.</div>
                    <div class="qna-answer">회원정보 관리에서 비밀번호 변경 버튼을 눌러 진행하세요.</div>
                </div>
            </div>
        </main>
    </div>
</main>
{{> layout/footer}}

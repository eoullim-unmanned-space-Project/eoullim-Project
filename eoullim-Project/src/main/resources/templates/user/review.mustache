<link rel="stylesheet" href="/css/layout/header.css">
<link rel="stylesheet" href="/css/user/review.css">
{{> layout/header}}
<body>
<div class="mypage-container">
    {{> layout/sideBar}}
    <section class="mypage-main">

        <div class="booking-search">
            <h2>리뷰 조회</h2>
            <div class="booking-search-row">
                <input class="booking-input" type="text" placeholder="예약 코드를 입력해 주세요">
                <button class="booking-search-btn">조회</button>
            </div>
        </div>

        <div class="booking-list" id="booking-list"></div>
    </section>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const searchBtn = document.querySelector(".booking-search-btn");
        const searchInput = document.querySelector(".booking-input");
        const listRoot = document.getElementById("booking-list");

        async function sendSearch() {
            const code = (searchInput.value || "").trim();

            const res = await fetch(`/api/user/reviews?code=${encodeURIComponent(code)}`);
            if (!res.ok) {
                alert("리뷰 목록 조회 실패");
                return;
            }

            const data = await res.json();
            render(data);
        }

        function starsText(rating) {
            const r = Number(rating || 0);
            return `${"★".repeat(r)}${"☆".repeat(5 - r)}`;
        }

        function paymentStatusLabel(status) {
            switch (status) {
                case "COMPLETED": return "이용완료";
                case "SUCCESS": return "결제성공(이용전)";
                default: return status || "";
            }
        }

        function render(items) {
            listRoot.innerHTML = "";

            if (!items || items.length === 0) {
                listRoot.innerHTML = `
              <div class="empty-card">
                <p class="empty-title">리뷰 내역이 없습니다</p>
                <p class="empty-desc">결제/이용 내역이 존재하지 않습니다.</p>
              </div>`;
                return;
            }

            items.forEach(it => {
                const card = document.createElement("div");
                card.className = "booking-card";

                const isCompleted = it.paymentStatus === "COMPLETED";

                const statusText = it.hasReview
                        ? "리뷰 작성 완료"
                        : (isCompleted ? "리뷰 작성 가능" : "결제 완료 후 작성 가능");

                let actionHtml = "";

                if (it.hasReview) {
                    actionHtml = `
                  <div style="display:flex; gap:8px;">
                    <a class="booking-detail-btn"
                       href="/reviews/${it.reviewId}/update?placeId=${it.placeId}">
                       리뷰 수정
                    </a>
                    <button class="booking-detail-btn btn-delete-review"
                            type="button"
                            data-reviewid="${it.reviewId}">
                       리뷰 삭제
                    </button>
                  </div>
                `;
                } else {
                    if (isCompleted) {
                        actionHtml = `
                      <a class="booking-detail-btn"
                         href="/rooms/${it.roomId}/reviews/new?placeId=${it.placeId}&paymentId=${it.paymentId}">
                         리뷰 작성
                      </a>
                    `;
                    } else {
                        actionHtml = `
                      <button class="booking-detail-btn" type="button" disabled
                              style="background:#ccc; cursor:not-allowed;">
                        이용 완료 후 작성
                      </button>
                    `;
                    }
                }

                card.innerHTML = `
              <div class="booking-thumb">
                <img src="/images/room-sample.jpg" alt="이미지">
              </div>

              <div class="booking-content">
                <div class="booking-card-header">
                  <span class="booking-place">🚩${it.roomName}</span>
                  <span class="booking-status confirmed">${statusText}</span>
                </div>

                <div class="booking-card-body">
                  <div class="booking-info-row">
                    <span class="label">예약 코드</span>
                    <span class="booking-code">${it.bookingCode || ""}</span>
                  </div>

                  <div class="booking-info-row price">
                    <span class="label">결제 금액</span>
                    <span>${Number(it.amount || 0).toLocaleString()}원</span>
                  </div>

                  <div class="booking-info-row">
                    <span class="label">결제 상태</span>
                    <span>${paymentStatusLabel(it.paymentStatus)}</span>
                  </div>

                  ${it.hasReview ? `
                    <div class="booking-info-row">
                      <span class="label">별점</span>
                      <span>${starsText(it.rating)}</span>
                    </div>` : ""}
                </div>

                <div class="booking-card-footer">
                  ${actionHtml}
                </div>
              </div>
            `;

                listRoot.appendChild(card);
            });

            document.querySelectorAll(".btn-delete-review").forEach(btn => {
                btn.addEventListener("click", async () => {
                    const reviewId = btn.dataset.reviewid;
                    if (!confirm("리뷰를 삭제할까요?")) return;

                    const res = await fetch(`/api/user/reviews/${reviewId}`, { method: "DELETE" });
                    if (!res.ok) {
                        alert("리뷰 삭제 실패");
                        return;
                    }
                    sendSearch();
                });
            });
        }

        searchBtn.addEventListener("click", sendSearch);
        searchInput.addEventListener("keyup", e => {
            if (e.key === "Enter") sendSearch();
        });

        sendSearch();
    });
</script>

</body>
{{> layout/footer}}

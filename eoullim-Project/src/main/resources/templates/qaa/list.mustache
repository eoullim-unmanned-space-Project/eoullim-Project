{{> layout/header}}
<div>
    {{#qaaPage.content}}
        <div>
            <div>
                <h4>{{title}}</h4>
                <p>작성자 : {{name}} | 작성일 : {{createdAt}}</p>
                <a href="/qaa/{{id}}">상세보기</a>
            </div>
        </div>
    {{/qaaPage.content}}

    <ul>
        {{#qaaPage.previousPageNumber}}
            <li>
                <a href="/qaas/page={{qaaPage.previousPageNumber}}">Previous
            </li>
        {{/qaaPage.previousPageNumber}}
        {{^qaaPage.previousPageNumber}}
            <li>
                <a href="#">Previous</a>
            </li>
        {{/qaaPage.previousPageNumber}}

        {{#qaaPage.pageLinks}}
            <li>
                <a href="/qaas/page={{displayNumber}}&size={{qaaPage.size}}">{{displayNumber}}
            </li>
        {{/qaaPage.pageLinks}}

        {{#qaaPage.nextPageNumber}}
            <li>
                <a href="/qaas/page={{boardPage.nextPageNumber}}">Next
            </li>
        {{/qaaPage.nextPageNumber}}
        {{^qaaPage.nextPageNumber}}
            <li>
                <a href="#">Next</a>
            </li>
        {{/qaaPage.nextPageNumber}}
    </ul>

    <div>
        <div>
            <form action="/qaa" method="get" class="row g-3">
                <div class="col-md-8">
                    <label>
                        <input type="text" class="form-control" name="keyword" value="{{#keyword}}{{keyword}}{{/keyword}}">
                    </label>
                </div>
                <div class="col-md-2">
                    <input type="hidden" name="page" value="1">
                    <input type="hidden" name="size" value="{{qaaPage.size}}">
                    <button type="submit">검색</button>
                </div>
                <div class="col-md-2">
                    <a href="/qaa">초기화</a>
                </div>
            </form>
        </div>
    </div>
</div>
{{> layout/footer}}
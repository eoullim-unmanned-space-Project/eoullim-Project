<link rel="stylesheet" href="/css/qaa/qaa.css">
<link rel="stylesheet" href="/css/layout/header.css"/>
{{> layout/header}}
<div class="qaa-container">
    <div class="qaa-card">
        <div class="qaa-meta">
            <b>작성자</b>: {{qaa.name}}
            <b>조회수</b>: {{qaa.viewCount}}
        </div>

        <div class="qaa-title">
            <h2><b>{{qaa.title}}</b></h2>
        </div>

        <div class="qaa-btn-group" style="justify-content: flex-end">
            <form action="/qaas/{{qaa.id}}/update" method="get">
                <button class="qaa-btn qaa-btn-secondary">수정</button>
            </form>
            <form action="/qaas/{{qaa.id}}/delete" method="post">
                <button class="qaa-btn qaa-btn-danger">삭제</button>
            </form>
        </div>

        <div class="qaa-content">
            {{qaa.content}}
        </div>

        <div class="qaa-card">
            <form class="qaa-form" action="/qaa/{qaaId}/comments/new" method="post">
                <input type="hidden" name="qaaId" value="{{qaa.id}}">
                <textarea rows="2" name="content" placeholder="댓글을 입력하세요." style="justify-content: flex-start"></textarea>
                <div class="qaa-btn-group" style="justify-content: flex-end">
                    <button class="qaa-btn qaa-btn-primary" type="submit">댓글 등록</button>
                </div>
            </form>
        </div>

        {{#commentList}}
            <div class="comment-box">
                <div class="comment-item">
                    <div class="comment-header">
                        <div>{{name}}</div>
                        <small>{{createdAt}}</small>

                        {{#isEditing}}
                            <div class="comment-content">
                            {{#isOwner}}
                                <form class="qaa-form" action="/comments/{{id}}/update" method="post">
                                    <textarea name="content" autofocus>{{content}}</textarea>
                                    <div class="qaa-btn-group" style="justify-content: flex-end">
                                    <button class="qaa-btn qaa-btn-primary" type="submit" style="justify-content: flex-end">수정 완료</button>
                                    </div>
                                </form>
                            {{/isOwner}}
                            </div>
                        {{/isEditing}}

                        {{^isEditing}}
                            <div class="comment-content">
                                {{content}}


                            {{#isOwner}}
                                <div class="qaa-btn-group" style="justify-content: flex-end">
                                    <form action="/comments/{{id}}/update" method="get">
                                        <button class="qaa-btn qaa-btn-secondary" type="submit">수정</button>
                                    </form>
                                    <form action="/comments/{{id}}/delete" method="post">
                                        <button class="qaa-btn qaa-btn-danger" type="submit">삭제</button>
                                    </form>
                                </div>
                            {{/isOwner}}
                            </div>
                        {{/isEditing}}
                    </div>
                </div>
            </div>
        {{/commentList}}

        {{^commentList}}
            <div class="qaa-card">
                작성된 댓글이 없습니다.
            </div>
        {{/commentList}}
    </div>
</div>
{{> layout/footer}}
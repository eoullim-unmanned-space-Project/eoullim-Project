<link rel="stylesheet" href="/css/qaa/qaa.css">
<link rel="stylesheet" href="/css/layout/header.css"/>
{{> layout/header}}
<div class="qaa-container">
    <div class="qaa-card">
        <div class="qaa-title"><b>Q&A 작성</b></div>
        <div>
            <form class="qaa-form" action="/qaas/new" method="post">
                <div>
                    <input type="text" placeholder="제목을 입력하세요." name="title">
                </div>
                <div>
                    <textarea rows="10" name="content" placeholder="내용을 입력하세요."></textarea>
                </div>
                <button class="qaa-btn qaa-btn-primary">Q&A 작성 완료</button>
            </form>
        </div>
    </div>
</div>
{{> layout/footer}}
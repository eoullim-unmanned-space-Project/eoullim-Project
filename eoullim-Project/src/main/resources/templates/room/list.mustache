<link rel="stylesheet" href="/css/room/listStyle.css">
<link rel="stylesheet" href="/css/layout/header.css"/>
<link rel="stylesheet" href="/css/booking/bookingStyle.css">

{{> layout/header}}
<body>
<div class="container">
    <!--    <section class="section"></section>-->
    <section class="sub-section">
        <div class="hero-card">
            <div class="hero-img"></div>
            <div class="hero-body">
                <h1>{{place.name}}</h1>
                <p><img src="{{#place.profilePath}}{{place.profilePath}}{{/place.profilePath}}" alt="{{place.address}}<">  {{place.address}}</p>
            </div>
        </div>

        <div class="left">
            <div class="main-content">
                <input type="hidden" id="latitude" value="{{place.latitude}}">
                <input type="hidden" id="longitude" value="{{place.longitude}}">
                <p>룸 선택</p>
                <div class="room-list">
                    {{#roomList}}
                        <div class="room-card" data-room-id="{{roomId}}"><img src="{{roomImagePath}}" alt="{{name}}">
                            <p>{{name}}</p>
                        </div>

                    {{/roomList}}
                </div>
                <p>위치</p>
                <div id="map"></div>
                <section class="rules-section">
                    <h2>📌 이용 규칙 안내</h2>
                    <ul class="rules-list">
                        <li> ☑ <strong>예약 시간 엄수</strong> – 예약한 시간에 맞춰 입·퇴실해 주세요.</li>
                        <li> ☑ <strong>무단 이용 금지</strong> – 예약자 외 출입은 금지됩니다.</li>
                        <li> ☑ <strong>소음 주의</strong> – 주변 이용자를 위해 큰 소음은 삼켜주세요.</li>
                        <li> ☑ <strong>화기 사용 금지</strong> – 흡연 및 인화물 사용은 절대 금지입니다.</li>
                        <li> ☑ <strong>정리 정돈 필수</strong> – 이용 후 공간을 깨끗하게 정리해 주세요.</li>
                        <li> ☑ <strong>시설물 훼손 금지</strong> – 훼손 시 배상 책임이 발생할 수 있습니다.</li>
                        <li> ☑ <strong>CCTV 운영 중</strong> – 안전 및 분쟁 방지를 위해 촬영 중입니다.</li>
                        <li> ☑ <strong>문제 발생 시 즉시 연락</strong> – 비상 연락처로 바로 문의해주세요.</li>
                    </ul>
                </section>
            </div>
        </div>


        <div class="right">
            <div class="room-box">
                <h3 class="room-title">방</h3>
                <div class="room-img"  style="background-image: url('/img/main/크리스마스파티룸.jpg')" ></div>
                <p class="room-desc">
                    · 내용
                </p>
                <hr>
                <p class="room-info">
                    · 최대 인원: <strong>인원</strong>
                </p>
                <hr>
                <p class="room-info">
                    · 최소: 1시간부터 이용 가능
                </p>
                <hr>
                <p class="room-warning">
                    · 인원 초과 시 1인당 <strong>15,000원</strong> 추가
                </p>
            </div>


            <p><img src="/img/room/user.png" alt=""> 인원 수</p>
            <div class="people-box">
                <button type="button" id="minusBtn">−</button>
                <input type="text" id="peopleCount" value="1" min="1" readonly>
                <button type="button" id="plusBtn">+</button>
            </div>
            <div class="amount-box">
                <strong id="amount">0</strong>원
            </div>
            <div class="timeslot-container" id="timeslot">
                <div class="timeslot-item">

                </div>
            </div>
            <input type="hidden" id="roomId" value="${room.roomId}">
            <div class="booking-box">
                <button type="button" id="bookingBtn">예약하기</button>
            </div>
        </div>
    </section>
</div>

<!-- 리뷰 섹션 -->
<section class="review-section">
    <hr/>
    <div class="container">
        <h2 class="review-title">리뷰</h2>
        {{#reviews}}
            <div class="review-grid">
                <div class="review-card">
                    <div class="review-header">
                        <div class="review-user">
                            <p class="user-name">{{name}}</p>
                            <p class="user-star">{{#stars}}★{{/stars}}{{#emptyStars}}☆{{/emptyStars}}</p>
                        </div>
                    </div>

                    <p class="review-content">{{content}}</p>
                </div>
            </div>
        {{/reviews}}

        {{^reviews}}
            <div>아직 등록된 리뷰가 없습니다.</div>
        {{/reviews}}
    </div>
</section>

<script type="text/javascript" src="//dapi.kakao.com/v2/maps/sdk.js?appkey=cd663d21be538a20913843972ae7bf17"></script>
<script>

    let currentAllSlots = [];
    let selectedSlots = [];
    let currentYear = new Date().getFullYear();
    let currentMonth = new Date().getMonth();

    // 1. 카카오 맵 로드 (중복 제거 및 구조 정리)
    kakao.maps.load(function () {
        const latInput = document.getElementById("latitude");
        const lngInput = document.getElementById("longitude");

        // 값 가져오기 (문자열)
        let latitudeStr = latInput.value;
        let longitudeStr = lngInput.value;

        // 숫자로 변환
        let latitude = parseFloat(latitudeStr);
        let longitude = parseFloat(longitudeStr);


        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(() => {
                var lat = latitude;
                var lng = longitude;
                var mapContainer = document.getElementById('map');
                var mapOption = {center: new kakao.maps.LatLng(lat, lng), level: 6};
                var map = new kakao.maps.Map(mapContainer, mapOption);
                var marker = new kakao.maps.Marker({position: new kakao.maps.LatLng(lat, lng)});
                marker.setMap(map);
            }, function (error) {
                console.error("위치 정보를 가져올 수 없습니다.", error);
            });
        } else {
            alert("이 브라우저에서는 위치 정보를 지원하지 않습니다.");
        }
    });

    document.addEventListener("DOMContentLoaded", () => {

         function changeDate(dateStr) {
            console.log("전체 데이터(currentAllSlots):", currentAllSlots);
            console.log("내가 클릭한 날짜(dateStr):", dateStr);

            const filtered = currentAllSlots.filter(slot => {
                if (!slot.startTime) return false;

                const slotDate = slot.startTime.substring(0, 10);
                return slotDate === dateStr;
            });

            const container = document.querySelector("#timeslot");
            container.innerHTML = "";

            initTimeSlot(filtered);
        }

        let selectedSlots = [];

        // 1. 룸 리스트 가져오기
        document.querySelectorAll('.room-card').forEach(card => {
            card.addEventListener('click', async () => {
                let roomRoot = card.dataset.roomId;
                let roomId = Number(roomRoot);

                const response = await fetch(`/api/room/${roomId}`, {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        roomId: roomId
                    })
                });

                if (!response.ok) {
                    throw new Error("서버 오류");
                }
                let data = await response.json();

                RoomDetail(data.room);

            });

            // 2. 상세조회 가져오기 기능
            function RoomDetail(room) {
                currentAllSlots = room.timeSlots;

                const container = document.querySelector(".right");
                container.innerHTML = `
                 <div class="room-box">
                    <h3 class="room-title">${room.name}</h3>
                    <div class="room-img"  style="background-image: url('${room.roomImagePath}')" ></div>
                    <p class="room-desc">
                        · ${room.content}
                    </p>
                    <hr>
                    <p class="room-info">
                        · 최대 인원: <strong>${room.maxCapacity}</strong>
                    </p>
                    <hr>
                    <p class="room-info">
                        · 최소: 1시간부터 이용 가능
                    </p>
                    <hr>
                    <p class="room-warning">
                        · 인원 초과 시 1인당 <strong>15,000원</strong> 추가
                    </p>
                </div>

                  <div class="calendar-wrapper">
                    <div class="calendar-header">
                        <button type="button" id="prevMonth">&lt;</button>
                        <h3 id="calendarTitle"></h3>
                        <button type="button" id="nextMonth">&gt;</button>
                    </div>
                    <div class="calendar-days">
                        <div>일</div><div>월</div><div>화</div><div>수</div><div>목</div><div>금</div><div>토</div>
                    </div>
                    <div id="calendarGrid" class="calendar-grid">
                    </div>
                </div>

                <p><img src="/img/room/user.png" alt=""> 인원 수</p>
                <div class="people-box">
                    <button type="button" id="minusBtn">−</button>
                    <input type="text" id="peopleCount" value="1" min="1" readonly>
                    <button type="button" id="plusBtn">+</button>
                </div>
                <div class="amount-box">
                    <strong id="amount">0</strong>원
                </div>
                <div class="timeslot-container" id="timeslot">
                    <div class="timeslot-item">

                    </div>
                </div>
                <input type="hidden" id="roomId" value="${room.roomId}">
                <div class="booking-box">
                    <button type="button" id="bookingBtn">예약하기</button>
                </div>
                `;

                initCalendar(currentYear, currentMonth);

                initCapacity(room.maxCapacity);

                initSSE(room.roomId);

                const now = new Date();

                const todayStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;

                changeDate(todayStr);

                document.getElementById('bookingBtn').addEventListener('click', () => {
                    bookRoom();
                });
            }
        });

        function initCalendar(year, month) {
            const grid = document.getElementById('calendarGrid');

            const title = document.getElementById('calendarTitle');

            grid.innerHTML = '';
            title.innerText = `${year}년 ${month + 1}월`;

            const firstDay = new Date(year, month, 1).getDay();
            const lastDate = new Date(year, month + 1, 0).getDate();

            for(let month = 0; month < firstDay; month++) {
                const emptyDiv = document.createElement('div');
                grid.appendChild(emptyDiv);
            }

            for (let day = 1; day <= lastDate; day++) {
                const dayEl = document.createElement('div');
                dayEl.innerText = day;
                dayEl.className = 'calendar-day';

                const currentDay = day;
                const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;

                const hasData = currentAllSlots.some(slot => slot.startTime.startsWith(dateStr));

                if (!hasData) {
                    dayEl.classList.add('no-data');
                } else {
                    dayEl.onclick = () => {

                    const amountDiv = document.getElementById("amount");

                    amountDiv.innerHTML = '0';

                    document.querySelectorAll('.calendar-day').forEach(el => el.classList.remove('active'));

                    dayEl.classList.add('active');

                    changeDate(dateStr);
                    };
                }
                grid.appendChild(dayEl);
            }

            document.getElementById('prevMonth').onclick = () => {
                let newMonth = month - 1;
                let newYear = year;

                if(newMonth < 0) {
                    newMonth = 11;
                    newYear --;
                }

                currentYear = newYear;
                currentMonth = newMonth;
                initCalendar(currentYear, currentMonth);
            };

            document.getElementById('nextMonth').onclick = () => {
                let newMonth = month + 1;
                let newYear = year;

                if (newMonth > 11) {
                    newMonth = 0;
                    newYear++;
                }
                currentYear = newYear;
                currentMonth = newMonth;
                initCalendar(currentYear, currentMonth);
            }

        }

        // 6. 인원수 조절 스크립트
        function initCapacity(maxCapacity) {
            const maxPeople = maxCapacity;
            const minusBtn = document.getElementById('minusBtn');
            const plusBtn = document.getElementById('plusBtn');
            const input = document.getElementById('peopleCount');

            const updateButtons = () => {
                minusBtn.disabled = Number(input.value) <= 1;
                plusBtn.disabled = Number(input.value) >= maxPeople;
            };

            minusBtn.addEventListener('click', () => {
                let value = Number(input.value);
                if (value > 1) {
                    input.value = value - 1;
                    updateButtons();
                    calculateAmount();
                }
            });

            plusBtn.addEventListener('click', () => {
                let value = Number(input.value);
                if (value < maxPeople) {
                    input.value = value + 1;
                    updateButtons();
                    calculateAmount();
                }
            });

            updateButtons();
        }

        function formatTime(time) {
            return time.substring(11, 16);
        }

        function initTimeSlot(timeSlots) {
            const container = document.querySelector("#timeslot");

            selectedSlots = []; // 초기화

            timeSlots.forEach(slot => {
                const div = document.createElement("div");
                div.className = "timeslot";
                div.dataset.id = slot.timeSlotId;
                div.dataset.start = slot.startTime;
                div.dataset.end = slot.endTime;
                div.dataset.status = slot.status;

                div.innerText = `${formatTime(slot.startTime)} ~ ${formatTime(slot.endTime)}`;

                if (slot.status === "CLOSED" || slot.status === "HOLD") {
                    // 부모 div에 스타일 적용
                    div.classList.add("disabled");
                } else {
                    // 선택 가능한 슬롯 클릭 이벤트
                    div.addEventListener("click", () => {
                        if (div.classList.contains("active")) {
                            div.classList.remove("active");
                            selectedSlots = selectedSlots.filter(s => s.timeSlotId !== slot.timeSlotId);
                        } else {
                            div.classList.add("active");
                            selectedSlots.push(slot);
                        }
                        calculateAmount();
                    });
                }

                // 항상 container에 추가
                container.appendChild(div);
            });

            initSlider(container);
        }

        function initSSE(roomId) {
           const eventSource = new EventSource(`/api/sse/${roomId}/timeslot-connect`);

           eventSource.onopen = () => console.log("SSE 타임슬롯 연결 성공");
           eventSource.onerror = () => console.log("SSE 연결 에러 (자동연결 재시도)");

           window.addEventListener("beforeunload", () => {
               eventSource.close();
           });

           eventSource.addEventListener('timeSlotUpdate', (e) => {
                const updateSlots = JSON.parse(e.data);

                console.log("타임슬롯 변경:", updateSlots);

                updateTimeSlotUI(updateSlots);
           });
        }

        function updateTimeSlotUI(updateSlots) {
            const container = document.querySelector("#timeslot");
            container.innerHTML = "";

            updateSlots.forEach(slot => {
                div.className = "timeslot";
                div.dataset.id = slot.timeSlotId;
                div.dataset.start = slot.startTime;
                div.dataset.end = slot.endTime;
                div.dataset.status = slot.status;

                div.innerText = `${formatTime(slot.startTime)} ~ ${formatTime(slot.endTime)}`;

                if (slot.status === "CLOSED" || slot.status === "HOLD") {
                    div.classList.add("disabled");
                } else {
                    // 선택 가능한 슬롯 클릭 이벤트
                    div.addEventListener("click", () => {
                        if (div.classList.contains("active")) {
                            div.classList.remove("active");
                            selectedSlots = selectedSlots.filter(s => s.timeSlotId !== slot.timeSlotId);
                        } else {
                            div.classList.add("active");
                            selectedSlots.push(slot);
                        }
                        calculateAmount();
                    });
                }

                container.appendChild(div);
            });

            initSlider(container);
        }

        async function calculateAmount() {
            const roomId = document.getElementById("roomId")?.value;

            if (!roomId || selectedSlots.length === 0) {
                document.getElementById("amount").innerText = "0";
                return;
            }

            let timeSlotIds = selectedSlots.map(slot => slot.timeSlotId);

            try {
                const response = await fetch("/api/calculate-amount", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        roomId: Number(roomId),
                        timeSlotIds: timeSlotIds
                    })
                });

                if (!response.ok) {
                    throw new Error("금액 계산 실패");
                }

                const data = await response.json();

                const amountDiv = document.getElementById("amount");

                amountDiv.innerHTML = data.amount.amount.toLocaleString() ;

                return data.amount.amount;

            } catch (error) {
                console.error(error);
                alert("금액 계산 중 오류가 발생했습니다.");
            }
        }

        function initSlider(slider) {
            let isDown = false;
            let startX = 0;
            let startScrollLeft = 0;
            let moved = false;

            slider.addEventListener('mousedown', (e) => {
                isDown = true;
                moved = false;
                startX = e.clientX;
                startScrollLeft = slider.scrollLeft;
                slider.classList.add('active');
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                const dx = e.clientX - startX;
                if (Math.abs(dx) > 3) moved = true;
                if (moved) {
                    e.preventDefault();
                    slider.scrollLeft = startScrollLeft - dx;
                }
            });

            window.addEventListener('mouseup', () => {
                isDown = false;
                slider.classList.remove('active');
            });
        }

        async function bookRoom() {
            const roomId = Number(document.getElementById('roomId').value);
            const qty = Number(document.getElementById('peopleCount').value);
            const selectedSlots = document.querySelectorAll('.timeslot.active');
            const timeSlotIds = Array.from(selectedSlots).map(timeslot => parseInt(timeslot.dataset.id));

            try {
                if (timeSlotIds.length === 0) {
                    alert("타임슬롯을 선택해주세요.");
                    return;
                }

                // 총 금액 계산 (비동기 API 호출)
                const totalAmount = await calculateAmount();

                // 예약 API 호출
                const response = await fetch("/api/bookings", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        roomId: roomId,
                        qty: qty,
                        timeSlotIds: timeSlotIds,
                        totalAmount: totalAmount
                    })
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.message || "예약 실패");
                }

                const data = await response.json();
                alert("예약이 완료되었습니다. 결제페이지로 넘어갑니다.");
                location.href = `/booking/detail?code=${data.bookingCode}`;

            } catch (error) {
                alert(error.message);
            }
        }
    });


</script>
</body>
{{> layout/footer}}
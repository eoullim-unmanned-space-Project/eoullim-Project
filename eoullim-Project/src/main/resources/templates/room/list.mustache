<script type="text/javascript" src="//dapi.kakao.com/v2/maps/sdk.js?appkey=cd663d21be538a20913843972ae7bf17"></script>
<script>


    // 1. 카카오 맵 로드 (중복 제거 및 구조 정리)
    kakao.maps.load(function () {
        const latInput = document.getElementById("latitude");
        const lngInput = document.getElementById("longitude");

        // 값 가져오기 (문자열)
        let latitudeStr = latInput.value;
        let longitudeStr = lngInput.value;

        // 숫자로 변환
        let latitude = parseFloat(latitudeStr);
        let longitude = parseFloat(longitudeStr);


        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(() => {
                var lat = latitude;
                var lng = longitude;
                var mapContainer = document.getElementById('map');
                var mapOption = {center: new kakao.maps.LatLng(lat, lng), level: 6};
                var map = new kakao.maps.Map(mapContainer, mapOption);
                var marker = new kakao.maps.Marker({position: new kakao.maps.LatLng(lat, lng)});
                marker.setMap(map);
            }, function (error) {
                console.error("위치 정보를 가져올 수 없습니다.", error);
            });
        } else {
            alert("이 브라우저에서는 위치 정보를 지원하지 않습니다.");
        }
    });

    document.addEventListener("DOMContentLoaded", () => {

        let selectedSlots = [];
        const PRICE_PER_HOUR = 10000; // 시간당 요금

        // 1. 룸 리스트 가져오기
        document.querySelectorAll('.room-card').forEach(card => {
            card.addEventListener('click', async () => {
                let roomRoot = card.dataset.roomId;
                let roomId = Number(roomRoot);

                const response = await fetch(`/api/room/${roomId}`, {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        roomId: roomId
                    })
                });

                if (!response.ok) {
                    throw new Error("서버 오류");
                }
                let data = await response.json();
                console.log(data.room);

                RoomDetail(data.room);

            });
            // 2. 상세조회 가져오기 기능
            function RoomDetail(room) {
                const container = document.querySelector(".right");
                container.innerHTML = `
                 <div class="room-box">
                    <h3 class="room-title">${room.name}</h3>
                    <div class="room-img" ><img src="${room.roomImagePath}" ${room.name}"></div>
                    <p class="room-desc">
                        · ${room.content}
                    </p>
                    <hr>
                    <p class="room-info">
                        · 최대 인원: <strong>${room.maxCapacity}</strong>
                    </p>
                    <hr>
                    <p class="room-info">
                        · 최소: 1시간부터 이용 가능
                    </p>
                    <hr>
                    <p class="room-warning">
                        · 인원 초과 시 1인당 <strong>15,000원</strong> 추가
                    </p>
                </div>
                <p><img src="/img/room/user.png" alt=""> 인원 수</p>
                <div class="people-box">
                    <button type="button" id="minusBtn">−</button>
                    <input type="text" id="peopleCount" value="1" min="1" readonly>
                    <button type="button" id="plusBtn">+</button>
                </div>
                <div class="amount-box">
                    <strong id="amount">0</strong>원
                </div>
                <div class="timeslot-container" id="timeslot">
                    <div class="timeslot-item">

                    </div>
                </div>
                <input type="hidden" id="roomId" value="${room.roomId}">
                <div class="booking-box">
                    <button type="button" id="bookingBtn">예약하기</button>
                </div>
                `;

                initCapacity(room.maxCapacity);

                initTimeSlot(room.timeSlots);

                document.getElementById('bookingBtn').addEventListener('click', () => {
                    bookRoom();
                });
            }
        });

        // 6. 인원수 조절 스크립트
        function initCapacity(maxCapacity) {
            const maxPeople = maxCapacity;
            const minusBtn = document.getElementById('minusBtn');
            const plusBtn = document.getElementById('plusBtn');
            const input = document.getElementById('peopleCount');

            const updateButtons = () => {
                minusBtn.disabled = Number(input.value) <= 1;
                plusBtn.disabled = Number(input.value) >= maxPeople;
            };

            minusBtn.addEventListener('click', () => {
                let value = Number(input.value);
                if (value > 1) {
                    input.value = value - 1;
                    updateButtons();
                    calculateAmount();
                }
            });

            plusBtn.addEventListener('click', () => {
                let value = Number(input.value);
                if (value < maxPeople) {
                    input.value = value + 1;
                    updateButtons();
                    calculateAmount();
                }
            });

            updateButtons();
        }

        function formatTime(time) {
            return time.substring(11, 16);
        }

        function initTimeSlot(timeSlots) {
            const container = document.querySelector("#timeslot");
            container.innerHTML = "";

            selectedSlots = []; // 초기화

            timeSlots.forEach(slot => {
                const div = document.createElement("div");
                div.className = "timeslot";
                div.dataset.id = slot.timeSlotId;
                div.dataset.start = slot.startTime;
                div.dataset.end = slot.endTime;
                div.dataset.status = slot.status;

                div.innerText = `${formatTime(slot.startTime)} ~ ${formatTime(slot.endTime)}`;

                if (slot.status === "CLOSED") {
                    // 부모 div에 스타일 적용
                    div.classList.add("disabled");
                } else {
                    // 선택 가능한 슬롯 클릭 이벤트
                    div.addEventListener("click", () => {
                        if (div.classList.contains("active")) {
                            div.classList.remove("active");
                            selectedSlots = selectedSlots.filter(s => s.timeSlotId !== slot.timeSlotId);
                        } else {
                            div.classList.add("active");
                            selectedSlots.push(slot);
                        }
                        calculateAmount();
                    });
                }

                // 항상 container에 추가
                container.appendChild(div);
            });

            initSlider(container);
        }

        async function calculateAmount() {
            const roomId = document.getElementById("roomId")?.value;


            if (!roomId || selectedSlots.length === 0) {
                document.getElementById("amount").innerText = "0";
                return;
            }

            let timeSlotIds = selectedSlots.map(slot => slot.timeSlotId);

            try {
                const response = await fetch("/api/calculate-amount", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        roomId: Number(roomId),
                        timeSlotIds: timeSlotIds
                    })
                });

                if (!response.ok) {
                    throw new Error("금액 계산 실패");
                }

                const data = await response.json();

                let amountDiv = document.getElementById("amount");

                amountDiv.innerHTML = data.amount.amount ;

                return data.amount.amount;

            } catch (error) {
                console.error(error);
                alert("금액 계산 중 오류가 발생했습니다.");
            }
        }

        function initSlider(slider) {
            let isDown = false;
            let startX = 0;
            let startScrollLeft = 0;
            let moved = false;

            slider.addEventListener('mousedown', (e) => {
                isDown = true;
                moved = false;
                startX = e.clientX;
                startScrollLeft = slider.scrollLeft;
                slider.classList.add('active');
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                const dx = e.clientX - startX;
                if (Math.abs(dx) > 3) moved = true;
                if (moved) {
                    e.preventDefault();
                    slider.scrollLeft = startScrollLeft - dx;
                }
            });

            window.addEventListener('mouseup', () => {
                isDown = false;
                slider.classList.remove('active');
            });
        }

        async function bookRoom() {
            const roomId = Number(document.getElementById('roomId').value);
            const qty = Number(document.getElementById('peopleCount').value);
            const selectedSlots = document.querySelectorAll('.timeslot.active');
            const timeSlotIds = Array.from(selectedSlots).map(timeslot => parseInt(timeslot.dataset.id));


            try {
                if (timeSlotIds.length === 0) {
                    alert("타임슬롯을 선택해주세요.");
                    return;
                }

                // 총 금액 계산 (비동기 API 호출)
                const totalAmount = await calculateAmount();

                // 예약 API 호출
                const response = await fetch("/api/bookings", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        roomId: roomId,
                        qty: qty,
                        timeSlotIds: timeSlotIds,
                        totalAmount: totalAmount
                    })
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.message || "예약 실패");
                }

                const data = await response.json();
                alert("예약이 완료되었습니다. 결제페이지로 넘어갑니다.");
                location.href = `/booking/detail?code=${data.bookingCode}`;

            } catch (error) {
                alert(error.message);
            }
        }
    });


</script>
</body>
{{> layout/footer}}
                <div class="timeslot" data-id="3">02:00 ~ 03:00</div>
                <div class="timeslot" data-id="4">03:00 ~ 04:00</div>
                <div class="timeslot" data-id="5">04:00 ~ 05:00</div>
                <div class="timeslot" data-id="6">05:00 ~ 06:00</div>
                <div class="timeslot" data-id="7">06:00 ~ 07:00</div>
                <div class="timeslot" data-id="8">07:00 ~ 08:00</div>
                <div class="timeslot" data-id="9">08:00 ~ 09:00</div>
                <div class="timeslot" data-id="10">09:00 ~ 10:00</div>
                <div class="timeslot" data-id="11">10:00 ~ 11:00</div>
                <div class="timeslot" data-id="12">11:00 ~ 12:00</div>
                <div class="timeslot" data-id="13">12:00 ~ 13:00</div>
                <div class="timeslot" data-id="14">13:00 ~ 14:00</div>
                <div class="timeslot" data-id="15">14:00 ~ 15:00</div>
                <div class="timeslot" data-id="16">15:00 ~ 16:00</div>
                <div class="timeslot" data-id="17">16:00 ~ 17:00</div>
                <div class="timeslot" data-id="18">17:00 ~ 18:00</div>
                <div class="timeslot" data-id="19">18:00 ~ 19:00</div>
                <div class="timeslot" data-id="20">19:00 ~ 20:00</div>
                <div class="timeslot" data-id="21">20:00 ~ 21:00</div>
                <div class="timeslot" data-id="22">21:00 ~ 22:00</div>
                <div class="timeslot" data-id="23">22:00 ~ 23:00</div>
                <div class="timeslot" data-id="24">23:00 ~ 24:00</div>
            </div>
            <input type="hidden" id="roomId" value="1">
            <div class="booking-box">
                <button id="bookingBtn">예약하기</button>
            </div>
        </div>
    </section>
</div>

<!-- 리뷰 섹션 -->

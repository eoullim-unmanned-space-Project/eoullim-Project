<script type="text/javascript" src="//dapi.kakao.com/v2/maps/sdk.js?appkey=cd663d21be538a20913843972ae7bf17"></script>
<script>
    // 1. 카카오 맵 로드 (중복 제거 및 구조 정리)
    kakao.maps.load(function () {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                var lat = position.coords.latitude;
                var lng = position.coords.longitude;
                var mapContainer = document.getElementById('map');
                var mapOption = { center: new kakao.maps.LatLng(lat, lng), level: 6 };
                var map = new kakao.maps.Map(mapContainer, mapOption);
                var marker = new kakao.maps.Marker({ position: new kakao.maps.LatLng(lat, lng) });
                marker.setMap(map);
            }, function (error) {
                console.error("위치 정보를 가져올 수 없습니다.", error);
            });
        } else {
            alert("이 브라우저에서는 위치 정보를 지원하지 않습니다.");
        }
    });

    // 2. 타임슬롯 슬라이더 제어
    const slider = document.querySelector('.timeslot-container');
    const slots = slider.querySelectorAll('.timeslot');

    let isDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let moved = false;

    slider.addEventListener('mousedown', (e) => {
        isDown = true;
        moved = false;
        startX = e.clientX;
        startScrollLeft = slider.scrollLeft;
    });

    window.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 3) moved = true;
        if (moved) {
            e.preventDefault();
            slider.scrollLeft = startScrollLeft - dx;
        }
    });

    window.addEventListener('mouseup', () => {
        isDown = false;
    });

    // 3. 가격 계산 함수
    async function calculatePrice(timeSlotIds) {
        const roomId = document.getElementById('roomId').value;
        try {
            const response = await fetch("/api/calculate-amount", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roomId: roomId, timeSlotIds: timeSlotIds })
            });

            const result = await response.json();
            const amount = result.amount.amount;
            updateBookingButton(amount);
            return amount;
        } catch (error) {
            console.log("금액 계산에 실패했습니다.", error.message);
            const selectSlots = document.querySelectorAll('.timeslot.selected');
            selectSlots.forEach(slot => { slot.classList.remove('selected'); });
            alert("금액을 불러오는 중 오류가 발생하여 선택이 초기화되었습니다.");
        }
    }

    // 4. 슬롯 클릭 이벤트
    slots.forEach(slot => {
        slot.addEventListener('click', () => {
            slot.classList.toggle('selected');
            const selectedSlots = document.querySelectorAll('.timeslot.selected');
            const timeSlotIds = Array.from(selectedSlots).map(timeslot => parseInt(timeslot.dataset.id));

            if (timeSlotIds.length > 0) {
                calculatePrice(timeSlotIds);
            } else {
                updateBookingButton(0);
            }
        });
    });

    // 5. UI 업데이트
    function updateBookingButton(amount) {
        const totalAmount = document.getElementById('amount');
        if (amount > 0) {
            totalAmount.innerText = `${amount.toLocaleString()}`;
        } else {
            totalAmount.innerText = "0";
        }
    }

    // 6. 인원수 조절 스크립트
    document.addEventListener('DOMContentLoaded', () => {
        const maxPeople = 6;
        const minusBtn = document.getElementById('minusBtn');
        const plusBtn = document.getElementById('plusBtn');
        const input = document.getElementById('peopleCount');

        const updateButtons = () => {
            minusBtn.disabled = Number(input.value) <= 1;
            plusBtn.disabled = Number(input.value) >= maxPeople;
        };

        minusBtn.addEventListener('click', () => {
            let value = Number(input.value);
            if (value > 1) {
                input.value = value - 1;
                updateButtons();
            }
        });

        plusBtn.addEventListener('click', () => {
            let value = Number(input.value);
            if (value < maxPeople) {
                input.value = value + 1;
                updateButtons();
            }
        });

        updateButtons();
    });

    // 7. 예약하기 버튼 클릭 이벤트 (수정 포인트)
    document.getElementById('bookingBtn').addEventListener('click', async () => {
        const roomId = Number(document.getElementById('roomId').value);
        const qty = Number(document.getElementById('peopleCount').value);
        const selectedSlots = document.querySelectorAll('.timeslot.selected');
        const timeSlotIds = Array.from(selectedSlots).map(timeslot => parseInt(timeslot.dataset.id));

        try {
            if (timeSlotIds.length === 0) {
                alert("타임슬롯을 선택해주세요.");
                return;
            }

            alert(timeSlotIds);

            const totalAmount = await calculatePrice(timeSlotIds);

            const response = await fetch("/api/bookings", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    roomId: roomId,
                    qty: qty,
                    timeSlotIds: timeSlotIds,
                    totalAmount: totalAmount
                })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.message || "예약 실패");
            }

            const data = await response.json();
            alert("예약이 완료되었습니다. 결제페이지로 넘어갑니다.");
            location.href = `/booking/detail?code=${data.bookingCode}`;

        } catch (error) {
            alert(error.message);
        }
    });
</script>
</body>
{{> layout/footer}}
<link rel="stylesheet" href="/css/booking/bookingStyle.css">

{{> layout/header}}
<body>

<div class="container">
    {{#booking}}
        <div class="hero-card">
            <div class="hero-img"></div>
            <div class="hero-body">
                <div class="status-badge">예약 {{status}}</div>
                <h1>{{placeName}}</h1>
                <p><img src="/img/room/주소.png" alt="주소이미지">  {{address}}</p>
            </div>
        </div>

        <div class="grid-layout">
            <div class="main-info">
                <div class="card-section">
                    <span class="section-label">선택하신 공간</span>
                    <div class="room-container">
                        <img src="https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&q=80&w=300" alt="Room Image" class="room-thumb">
                        <div class="room-info">
                            <h3>{{roomName}}</h3>
                            <p>{{content}}</p>
                        </div>
                    </div>
                </div>

                <div class="card-section">
                    <span class="section-label">이용 일정</span>
                    <div class="slot-list">
                        {{#timeSlots}}
                            <div class="slot-item">
                                <span style="color: var(--text-sub);">예약 시간</span>
                                <span>{{startTime}} — {{endTime}}</span>
                            </div>
                        {{/timeSlots}}
                    </div>
                </div>
            </div>

            <div class="side-info">
                <div class="card-section">
                    <span class="section-label">예약 상세 내역</span>
                    <div class="summary-item">
                        <span class="label">예약자명</span>
                        <span class="val">{{username}}님</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">이용 날짜</span>
                        <span class="val">{{bookingDate}}</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">이용 인원</span>
                        <span class="val">{{qty}}명</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">예약코드</span>
                        <span class="val"><strong>{{bookingCode}}</strong></span>
                    </div>
                    <div class="total-row">
                        <span style="font-weight: 700; font-size: 15px;">총 결제 금액</span>
                        <span>{{amount}}원</span>
                    </div>
                    <div class="btn-group">
                        <button class="btn btn-primary" id="paymentBtn">결제하기</button>
                        <button class="btn btn-secondary">취소하기</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="payment-root"
             data-booking-code="{{bookingCode}}"
             data-room-name="{{roomName}}"
        >
        </div>
        </div>
    {{/booking}}

<div id="user-root"
     data-user-name="{{user.name}}"
     data-user-email="{{user.email}}"
>

</div>
<script src="https://cdn.iamport.kr/v1/iamport.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
         // 1. 초기 설정 및 데이터 추출
         const channelKey = 'channel-key-20a2905a-5dbf-4f2d-a466-013da8c5e67c';

         // 데이터가 없을 경우를 대비해 안전하게 요소 확인
         const paymentRoot = document.getElementById('payment-root');
         const userRoot = document.getElementById('user-root');

         if (!paymentRoot || !userRoot) {
             console.error("필요한 데이터 태그(payment-root 또는 user-root)를 찾을 수 없습니다.");
             return;
         }

         const bookingCode = paymentRoot.dataset.bookingCode;
         const roomName = paymentRoot.dataset.roomName;
         const email = userRoot.dataset.email;
         const phone = userRoot.dataset.phone;
         const name = userRoot.dataset.name;

         const paymentBtn = document.getElementById('paymentBtn');

         paymentBtn.addEventListener('click', async () => {
             if (!confirm("결제를 원하시면 확인 버튼을 눌러주세요")) {
                 return;
             }

             try {
                 // 3. 서버에 결제 준비 요청 (사전 검증용)
                 const paymentKeyResponse = await fetch("/api/payment/prepare", {
                     method: "POST",
                     headers: {
                         "Content-Type": "application/json"
                     },
                     body: JSON.stringify({ bookingCode: bookingCode })
                 });

                 if (!paymentKeyResponse.ok) {
                     throw new Error("결제 준비 서버 통신 실패");
                 }

                 const data = await paymentKeyResponse.json();
                 console.log("서버 응답 데이터:", data);

                 // 4. 포트원 결제 실행
                 const { IMP } = window;
                 IMP.init('imp42133684');

                 IMP.request_pay({
                     channelKey: channelKey,
                     pay_method: "card",
                     merchant_uid: data.paymentId,
                     name: roomName,
                     amount: data.totalAmount,
                     buyer_email: email,
                     buyer_name: name,
                     buyer_tel: phone,
                     m_redirect_url: window.location.href
                 }, async (response) => {

                     if (response.error_code != null) {
                        return alert(`결제에 실패했습니다. 에러 내용:" ${response.error.msg}`);
                     }

                     const notified = await fetch("/api/payment/complete", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            imp_uid: response.imp_uid,
                            merchant_uid: response.merchant_uid
                        })
                     });

                 });

             } catch (error) {
                 console.error("결제 오류:", error);
                 alert("결제 진행 중 오류가 발생했습니다.");
             }
         }); // paymentBtn 이벤트 끝

     }); // DOMContentLoaded 끝
</script>

</body>
{{> layout/footer}}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const placeCreateBtn = document.getElementById("place-create-btn");
        const placeUpdateBtns = document.querySelectorAll(".place-update-btn");
        const placeDeleteBtns = document.querySelectorAll(".place-delete-btn");
        const placeDetailBtns = document.querySelectorAll(".place-detail-btn");
        const placeCreateModal = document.getElementById("place-create-modal");
        const placeUpdateModal = document.getElementById("place-update-modal");
        const placeDetailModal = document.getElementById("place-detail-modal");

        placeCreateBtn.addEventListener('click', () => {
            placeCreateModal.style.display = 'flex';
        });

        placeUpdateBtns.forEach(button => {
            button.addEventListener('click', () => {
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const category = button.getAttribute('data-category')
                const profilePath = button.getAttribute('data-profilePath');

                placeUpdateModal.style.display = 'flex';

                document.getElementById("update-place-id").textContent = id;
                document.getElementById("update-place-name").value = name;
                document.getElementById("update-place-category").value = category;
                document.getElementById("update-place-profileImage").value = profilePath;
            })
        });

        placeDetailBtns.forEach(button => {
            button.addEventListener('click', () => {
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const address = button.getAttribute('data-address');
                const latitude = button.getAttribute('data-latitude');
                const longitude = button.getAttribute('data-longitude');
                const category = button.getAttribute('data-category');
                const profileImage = button.getAttribute('data-profilePath');

                placeDetailModal.style.display = 'flex';

                document.getElementById("detail-place-id").textContent = id;
                document.getElementById("detail-place-name").textContent = name;
                document.getElementById("detail-place-address").textContent = address;
                document.getElementById("detail-place-latitude").textContent = latitude;
                document.getElementById("detail-place-longitude").textContent = longitude;
                document.getElementById("detail-place-category").textContent = category;
                document.getElementById("detail-place-profileImage").src = profileImage || '/default-image.png';
            })

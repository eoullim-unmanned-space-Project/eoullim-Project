{{> admin/layout/nav}}

<main>
    <header>
        <h1>환불관리</h1>
    </header>
    <div class="create-container">
        <div class="action-card" id="place-create-btn">
            <div class="icon-box">📍</div>
            <h3>장소 생성</h3>
            <p>새로운 사업장이나 위치를 등록합니다.</p>
        </div>
        <div class="action-card" id="room-create-btn">
            <div class="icon-box">🔑</div>
            <h3>방 생성</h3>
            <p>등록된 장소 내에 새로운 호실을 추가합니다.</p>
        </div>
    </div>

    <div class="content-surface">
        <div class="place-admin-search">
            <div class="section-admin-header"><h2>최근 장소 조회</h2></div>
            <div class="admin-place-search-controls">
                <form action="/admin/place" method="get" class="admin-place-form">
                    <select name="category" class="admin-place-select">
                        <option value="">전체</option>
                        <option value="PARTY">파티룸</option>
                        <option value="STUDY">스터디</option>
                        <option value="PRACTICE">연습실</option>
                    </select>
                    <input class="admin-place-input" type="text" name="placeKeyword" placeholder="장소를 입력해주세요."
                           value="{{placeKeyword}}">
                    <button class="admin-place-search-btn" type="submit">검색</button>
                </form>
                <form action="/admin/place" method="get">
                    <button class="admin-place-search-btn red" type="submit">초기화</button>
                </form>
            </div>
        </div>
        <table class="data-table">
            <thead>
            <tr class="th-list">
                <th>번호</th>
                <th>카테고리</th>
                <th>이름</th>
                <th>주소</th>
                <th>생성일</th>
                <th>수정일</th>
                <th>상세보기</th>
            </tr>
            </thead>

            <tbody>
            {{#placePage.content}}
                <tr class="tr-list">
                    <td>{{id}}</td>
                    <td><span class="badge">{{category}}</span></td>
                    <td>{{name}}</td>
                    <td>{{address}}</td>
                    <td>{{createdAt}}</td>
                    <td>{{updatedAt}}</td>
                    <td>
                        <button class="action-button detail place-update-btn" data-id="{{id}}"
                                data-name="{{name}}" data-category="{{category}}" data-profilePath="{{profilePath}}">수정
                        </button>
                        <button class="action-button delete place-delete-btn" data-id="{{id}}">삭제</button>
                        <button class="action-button update place-detail-btn" data-id="{{id}}"
                                data-name="{{name}}" data-address="{{address}}" data-latitude="{{latitude}}"
                                data-longitude="{{longitude}}"
                                data-category="{{category}}" data-profilePath="{{profilePath}}">상세보기
                        </button>
                    </td>
                </tr>
            {{/placePage.content}}
            </tbody>
        </table>
        <div class="admin-pagination">
            <ul class="pagination-admin-container">
                {{#placePage.previousPageNumber}}
                    <li class="admin-page-move">
                        <a href="/admin/place?page={{placePage.previousPageNumber}}" class="admin-page-link"><</a>
                    </li>
                {{/placePage.previousPageNumber}}
                {{^placePage.previousPageNumber}}
                    <li class="admin-page-move disabled">
                        <a href="#" class="admin-page-link"><</a>
                    </li>
                {{/placePage.previousPageNumber}}
                {{#placePage.pageLinks}}
                    <li class="admin-page-move {{#active}}active{{/active}}">
                        <a href="/admin/place?page={{displayNumber}}&size={{placePage.size}}"
                        class="admin-page-link">{{displayNumber}}</a>
                    </li>
                {{/placePage.pageLinks}}
                {{#placePage.nextPageNumber}}
                    <li class="admin-page-move">
                        <a href="/admin/place?page={{placePage.nextPageNumber}}" class="admin-page-link">></a>
                    </li>
                {{/placePage.nextPageNumber}}
                {{^placePage.nextPageNumber}}
                    <li class="admin-page-move disabled">
                        <a href="#" class="admin-page-link">></a>
                    </li>
                {{/placePage.nextPageNumber}}
            </ul>
        </div>
    </div>

    <!-- 방 페이지 -->
    <div class="content-surface">
        <div class="place-admin-search">
            <div class="section-admin-header"><h2>최근 방 조회</h2></div>
            <div class="admin-place-search-controls">
                <form action="/admin/place" method="get" class="admin-place-form">
                    <select name="status" class="admin-place-select">
                        <option value="">전체</option>
                        <option value="OPEN">열림</option>
                        <option value="CLOSED">닫힘</option>
                    </select>
                    <input class="admin-place-input" type="text" name="roomKeyword" placeholder="방을 입력해주세요."
                           value="{{roomKeyword}}">
                    <button class="admin-place-search-btn" type="submit">검색</button>
                </form>
                <form action="/admin/place" method="get">
                    <button class="admin-place-search-btn red" type="submit">초기화</button>
                </form>
            </div>
        </div>
        <table class="data-table">
            <thead>
            <tr class="th-list">
                <th>방 번호</th>
                <th>상태</th>
                <th>장소 번호</th>
                <th>이름</th>
                <th>내용</th>
                <th>최대 인원</th>
                <th>가격</th>
                <th>상세보기</th>
            </tr>
            </thead>

            <tbody>
            {{#roomList.content}}
                <tr class="tr-list">
                    <td>{{roomId}}</td>
                    <td><span class="badge">{{status}}</span></td>
                    <td>{{placeId}}</td>
                    <td>{{name}}</td>
                    <td>{{content}}</td>
                    <td>{{maxCapacity}}</td>
                    <td>{{defaultPrice}}</td>
                    <td>
                        <button class="action-button detail room-update-btn" data-place-id="{{placeId}}"
                                data-room-id="{{roomId}}" data-content="{{content}}" data-max-capacity="{{maxCapacity}}"
                                data-default-price="{{defaultPrice}}"
                                data-name="{{name}}">수정
                        </button>
                        <button class="action-button delete room-delete-btn" data-room-id="{{roomId}}">삭제
                        </button>
                        <button class="action-button update room-detail-btn" data-place-id="{{placeId}}"
                                data-room-id="{{roomId}}"
                                data-name="{{name}}" data-content="{{content}}" data-max-capacity="{{maxCapacity}}"
                                data-default-price="{{defaultPrice}}"
                                data-status="{{status}}" data-room-image-path="{{roomImagePath}}">상세보기
                        </button>
                    </td>
                </tr>
            {{/roomList.content}}
            </tbody>
        </table>
        <div class="admin-pagination">
            <ul class="pagination-admin-container">
                {{#roomList.previousPageNumber}}
                    <li class="admin-page-move">
                        <a href="/admin/place?page={{roomList.previousPageNumber}}" class="admin-page-link"><</a>
                    </li>
                {{/roomList.previousPageNumber}}
                {{^roomList.previousPageNumber}}
                    <li class="admin-page-move disabled">
                        <a href="#" class="admin-page-link"><</a>
                    </li>
                {{/roomList.previousPageNumber}}
                {{#roomList.pageLinks}}
                    <li class="admin-page-move {{#active}}active{{/active}}">
                        <a href="/admin/place?page={{displayNumber}}&size={{roomList.size}}"
                        class="admin-page-link">{{displayNumber}}</a>
                    </li>
                {{/roomList.pageLinks}}
                {{#roomList.nextPageNumber}}
                    <li class="admin-page-move">
                        <a href="/admin/place?page={{roomList.nextPageNumber}}" class="admin-page-link">></a>
                    </li>
                {{/roomList.nextPageNumber}}
                {{^roomList.nextPageNumber}}
                    <li class="admin-page-move disabled">
                        <a href="#" class="admin-page-link">></a>
                    </li>
                {{/roomList.nextPageNumber}}
            </ul>
        </div>
    </div>

</main>

<!-- 장소 -->
<!-- 생성 모달 -->
<div class="modal-overlay" id="place-create-modal">
    <div class="modal-card">
        <div class="place-modal-header">
            <h2>장소 생성</h2>
        </div>

        <div class="modal-input-box">
            <div class="input-label">
                <span class="data-label">장소 명</span>
                <input type="text" class="data-value" id="place-name" placeholder="장소명을 입력해주세요." required>
            </div>
            <div class="input-label">
                <span class="data-label">주소</span>
                <input type="text" class="data-value" id="place-address" placeholder="주소를 입력해주세요." required>
            </div>
            <div class="input-label">
                <span class="data-label">위도</span>
                <input type="text" class="data-value" id="place-latitude" placeholder="위도를 입력해주세요." required>
            </div>
            <div class="input-label">
                <span class="data-label">경도</span>
                <input type="text" class="data-value" id="place-longitude" placeholder="경도를 입력해주세요." required>
            </div>
            <div class="input-label">
                <span class="data-label">카테고리</span>
                <select class="data-value" id="place-category" required>
                    <option VALUE="">선택하세요</option>
                    <option VALUE="PARTY">PARTY</option>
                    <option VALUE="STUDY">STUDY</option>
                    <option VALUE="PRACTICE">PRACTICE</option>
                </select>
            </div>
            <div class="input-label">
                <span class="data-label">장소 이미지 첨부</span>
                <input type="file" class="form-control" id="place-profileImage" name="profileImage"
                       accept="image/*">
                <small class="form-text text-muted mt-1">이미지 파일만 업로드 가능합니다(JPG, PNG, GIF)</small>
            </div>
        </div>

        <div class="modal-actions">
            <button class="btn-confirm btn-blue" onclick="savePlaceModal()">생성</button>
            <button type="button" class="btn-confirm btn-red" onclick="closePlaceModal()">닫기</button>
        </div>
    </div>
</div>


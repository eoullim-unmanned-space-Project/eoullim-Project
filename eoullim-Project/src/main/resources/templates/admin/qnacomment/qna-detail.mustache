<link rel="stylesheet" href="/css/admin/layout/nav.css">
<link rel="stylesheet" href="/css/admin/qna/qna.css">

<div class="admin-layout">
    {{> admin/layout/nav}}

    <main class="admin-main">
        <div class="qna-container">

            <div class="qna-card">
                <h2>{{qna.title}}</h2>
                <p>작성자 : {{qna.name}} | 작성일 : {{qna.createdAt}} | 조회수 : {{qna.viewCount}}</p>
                <hr/>
                <div style="white-space: pre-wrap;">{{qna.content}}</div>

                <form action="/admin/qnas/{{qna.id}}/delete" method="post" style="margin-top:15px;">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <button class="qna-btn qna-btn-danger" type="submit">QnA 삭제</button>
                </form>
            </div>

            <div class="qna-card">
                <form class="qna-form" action="/admin/qnas/{{qna.id}}/comments/new" method="post">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <input type="hidden" name="qnaId" value="{{qna.id}}">
                    <textarea name="content" placeholder="댓글을 입력해주세요."></textarea>

                    <div class="qna-btn-group" style="justify-content:flex-end;">
                        <button class="qna-btn qna-btn-primary" type="submit">댓글 등록</button>
                        <a href="/admin/qnas" class="qna-btn qna-btn-secondary">목록</a>
                    </div>
                </form>
            </div>

            <div class="qna-card">
                <h3>댓글</h3>

                {{#commentList}}
                    <div class="qna-list-item">
                        <p><b>{{name}}</b> | {{createdAt}}</p>

                        {{#isEditing}}
                            <form class="qna-form" action="/admin/comments/{{id}}/update" method="post">
                                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                                <textarea name="content">{{content}}</textarea>
                                <div class="qna-btn-group">
                                    <a href="/admin/qnas/{{qna.id}}" class="qna-btn qna-btn-secondary">취소</a>
                                </div>
                            </form>
                        {{/isEditing}}

                        {{^isEditing}}
                            <div style="white-space: pre-wrap;">{{content}}</div>
                            <div class="qna-btn-group" style="justify-content:flex-end;">
                                <form action="/admin/comments/{{id}}/delete" method="post">
                                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                                    <button class="qna-btn qna-btn-danger" type="submit">삭제</button>
                                </form>
                            </div>
                        {{/isEditing}}
                    </div>
                {{/commentList}}

                {{^commentList}}
                    <div>아직 댓글이 없습니다.</div>
                {{/commentList}}
            </div>

        </div>
    </main>
</div>

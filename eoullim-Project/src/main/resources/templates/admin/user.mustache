<link rel="stylesheet" href="/css/admin/user/user.css">
{{> admin/layout/nav}}
<main>
    <header>
        <h1>회원관리</h1>
    </header>
    <div class="content-surface">
        <div class="section-header">
            <h2>최근 회원 내역</h2>
        </div>
        <table class="data-table">
            <thead>
            <tr class="th-list">
                <th>회원번호</th>
                <th>현재상태</th>
                <th>아이디</th>
                <th>이름</th>
                <th>가입경로</th>
                <th>가입일</th>
                <th>버튼</th>
            </tr>
            </thead>
            <tbody>

            {{#adminUserList}}
                <tr class="tr-list">
                    <td>{{id}}</td>
                    <td>
                        <span class="user-status" >
                            {{displayStatus}}
                        </span>
                    </td>
                    <td>{{loginId}}</td>
                    <td>{{name}}</td>
                    <td>
                        <span class="provider">
                            {{displayProvider}}
                        </span>
                    </td>
                    <td>{{createdAt}}</td>
                    <td style="display: flex; justify-content: center; gap: 12px;">
                        <button class="action-button update detail-btn" onclick="userDetailModal({{id}})">상세보기</button>
                    </td>
                </tr>
            {{/adminUserList}}
            </tbody>
        </table>
    </div>

</main>

<div class="modal-overlay" id="modal-detail">
    <div class="modal-card">
        <div class="modal-header">
            <h2>회원 상세 정보</h2>
        </div>

        <div class="modal-body">
        <div class="modal-data-box">
            <div class="data-row">
                <span class="data-label">로그인 ID</span>
                <span class="data-value" id="user-login-id"></span>
            </div>
            <div class="data-row">
                <span class="data-label">이름</span>
                <span class="data-value" id="name"></span>
            </div>
            <div class="data-row">
                <span class="data-label">전화번호</span>
                <span class="data-value" id="user-phone"></span>
            </div>
            <div class="data-row">
                <span class="data-label">이메일</span>
                <span class="data-value" id="user-email"></span>
            </div>
            <div class="data-row">
                <span class="data-label">가입경로</span>
                <span class="data-value" id="user-provider"></span>
            </div>
            <div class="data-row">
                <span class="data-label">가입일</span>
                <span class="data-value" id="user-created-at"></span>
            </div>
            <div class="data-row">
                <span class="data-label">수정일</span>
                <span class="data-value" id="user-updated-at"></span>
            </div>
            <div class="data-row">
                <span class="data-label">현재 상태</span>
                <span class="data-value user-status" id="user-status"></span>
            </div>
            <div class="data-row" id="suspendReasonDiv" style="display: none">
                <label class="data-label">정지 사유</label>
                <textarea id="suspendReasonInput" rows="3" placeholder="정지 사유를 입력해주세요."></textarea>
            </div>
        </div>
        </div>

        <div class="modal-actions" id="modal-footer">
            <button class="btn-confirm btn-blue" id="actionBtn">정지</button>
            <button class="btn-ghost" onclick="closeModal()">닫기</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        providerStatus();
        userStatus();
    })

    function updateActionBtn(actionBtn, text, colorClass, clickHandler) {
        actionBtn.innerText = text;
        actionBtn.className = "btn-confirm" + colorClass;
        actionBtn.onclick = null;
        actionBtn.addEventListener('click', clickHandler);
    }

    function formatDateTime(dateTimeStr) {
        if (!dateTimeStr) return "/";

        const date = new Date(dateTimeStr);

        const yyyy = date.getFullYear();
        const mm = String(date.getMonth() + 1).padStart(2, '0');
        const dd = String(date.getDate()).padStart(2, '0');
        const hh = String(date.getHours()).padStart(2, '0');
        const min = String(date.getMinutes()).padStart(2, '0');

        return `${yyyy}-${mm}-${dd} ${hh}:${min}`;
    }

    function userDetailModal(userId) {
        fetch(`/api/admin/users/${userId}`)
                .then(res => res.json())
                .then(data => {
                    console.log("데이터 표시 " + data);
                    document.getElementById('user-login-id').innerText = data.loginId;
                    document.getElementById('name').innerText = data.name;
                    document.getElementById('user-phone').innerText = data.phone ?? "/";
                    document.getElementById('user-email').innerText = data.email ?? "/";
                    document.getElementById('user-provider').innerText = data.displayProvider;
                    document.getElementById('user-created-at').innerText = formatDateTime(data.createdAt);
                    document.getElementById('user-updated-at').innerText = formatDateTime(data.updatedAt);

                    const userStatusElement = document.getElementById('user-status');

                    userStatusElement.innerText = data.displayStatus || data.status;
                    userStatusElement.className = 'data-value user-status ' + (data.statusClass || '').toLowerCase();

                    const userProviderElement = document.getElementById('user-provider');
                    userProviderElement.innerText = data.displayProvider || "";
                    userProviderElement.className = 'data-value provider-badge' + (data.providerClass || '').toLowerCase();


                    const suspendDiv = document.getElementById('suspendReasonDiv');
                    const actionBtn = document.getElementById('actionBtn');
                    const reasonInput = document.getElementById('suspendReasonInput')

                    suspendDiv.style.display = 'none';
                    reasonInput.value = "";

                    actionBtn.dataset.userId = userId;

                    if (data.status === "SUSPENDED") {
                        // 정지 상태일 때
                        suspendDiv.style.display = 'block';
                        reasonInput.value = data.suspendedReason || "";

                        reasonInput.readOnly = true;
                        reasonInput.classList.add('readonly');

                        updateActionBtn(actionBtn, "복구", "btn-blue", restoreUser);

                    } else if (data.status === "WITHDRAWN") {
                        // 탈퇴 상태일 때
                        suspendDiv.style.display = 'none';  // 정지사유 없음
                        reasonInput.value = "";
                        reasonInput.readOnly = true;
                        reasonInput.classList.add('readonly');

                        updateActionBtn(actionBtn, "탈퇴복구", "btn-blue", restoreUser);

                    } else {
                        // 정상 상태 (ACTIVE 등)
                        suspendDiv.style.display = 'none';
                        reasonInput.readOnly = false;
                        reasonInput.classList.remove('readonly');
                        updateActionBtn(actionBtn, "정지", "btn-red", suspendUser);
                    }

                    document.getElementById('modal-detail').style.display = 'flex';
                })
                .catch(err => {
                    console.error(err);
                    alert("유저 정보를 불러오지 못했습니다.");

                })
    }

    function closeModal() {
        document.getElementById('modal-detail').style.display = 'none';
    }

    function suspendUser() {
        const userId = this.dataset.userId;
        const reason = document.getElementById('suspendReasonInput').value.trim();
        if (!reason) {
            alert("정지 사유를 입력해주세요.");
            document.getElementById('suspendReasonDiv').style.display = 'block';
            return;
        }

        if (!confirm("정지 처리하시겠습니까?")) return;

        fetch(`/api/admin/users/${userId}/suspend`, {
            method: "PATCH",
            headers: {'Content-Type': 'application/json',
                ...getCsrfHeaders()},
            body: JSON.stringify({reason})
        }).then(res => {
            if (res.ok) location.reload();
            else alert("정지 처리 실패");
        })
    }

    function restoreUser() {
        const userId = this.dataset.userId;
        if (!confirm("복구 처리하시겠습니까?")) return;

        fetch(`/api/admin/users/${userId}/restore`, {
            method: 'PATCH',
            headers: {
                ...getCsrfHeaders()
            }})
                .then(res => {
                    if (res.ok) location.reload();
                    else alert("복구 처리 실패");
                });
    }

    function formatDateTime(dateTomeStr) {
        if (!dateTomeStr) return "/";
        const d = new Date(dateTomeStr);
        return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
    }

    function providerStatus() {
        const providerList = document.querySelectorAll('.provider');

        providerList.forEach(providerEl => {
            if (providerEl) {
                const status = providerEl.innerText.trim();

                if (status === 'LOCAL') {
                    providerEl.classList.add('local');
                } else if (status === 'KAKAO') {
                    providerEl.classList.add('kakao');
                }
            }
        });
    }

    function userStatus() {
        const userStatusList = document.querySelectorAll('.user-status');

        userStatusList.forEach(userStatusEl => {
            if (userStatusEl) {
                const userStatus = userStatusEl.innerHTML.trim();

                if (userStatus === '활성화') {
                    userStatusEl.classList.add('active');
                } else if (userStatus === '탈퇴') {
                    userStatusEl.classList.add('suspended');
                } else {
                    userStatusEl.classList.add('unknown');
                }
            }
        });
    }
</script>
</body>
</html>
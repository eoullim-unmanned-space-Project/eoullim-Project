<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Management Console</title>
</head>

<style>
    :root {
        --point-color: #3182f6;
        --bg-canvas: #f2f4f6;
        --bg-surface: #ffffff;
        --text-primary: #191f28;
        --text-secondary: #4e5968;
        --text-tertiary: #8b95a1;
        --line-default: #e5e8eb;
        --line-subs: #f9fafb;
    }

    * {
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
    }

    body {
        margin: 0; padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Pretendard", sans-serif;
        background-color: var(--bg-canvas);
        color: var(--text-primary);
        display: flex;
        min-height: 100vh;
    }

    /* Sidebar Navigation */
    nav {
        width: 260px;
        height: 100vh;
        background: white;
        padding: 40px 20px;
        position: fixed;
        border-right: 1px solid var(--border-color);
    }

    .nav-brand {
        font-size: 22px;
        font-weight: 800;
        margin-bottom: 40px;
        padding-left: 12px;
    }

    .nav-menu {
        list-style: none;
        padding: 0;
    }

    .nav-item {
        padding: 14px 16px;
        border-radius: 12px;
        font-weight: 600;
        color: var(--text-sub);
        cursor: pointer;
        margin-bottom: 4px;
        transition: 0.2s;
    }

    .nav-item:hover,
    .nav-item.active {
        background-color: #f9fafb;
        color: var(--toss-blue);
    }

    main {
        margin-left: 280px;
        padding: 40px 20px;
        width: auto;
        flex-grow: 1;
        box-sizing: border-box;
    }

    header {
        margin-bottom: 32px;
        padding-left: 8px;
    }

    header h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.6px; margin: 0; }

    /* 섹션 카드 (가로로 가득 참) */
    .content-surface {
        background: var(--bg-surface);
        border-radius: 24px;
        padding: 32px 40px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.01);
        width: 100%;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .section-header h2 { font-size: 20px; font-weight: 700; margin: 0; }

    /* 데이터 테이블 (유연한 너비) */
    .data-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: auto;
    }

    .data-table th {
        text-align: left;
        padding: 16px;
        color: var(--text-tertiary);
        font-size: 14px;
        font-weight: 600;
        border-bottom: 1px solid var(--line-default);
    }

    .data-table td {
        padding: 24px 16px;
        font-size: 15px;
        border-bottom: 1px solid var(--line-subs);
        color: var(--text-secondary);
    }

    .data-table tr:last-child td { border-bottom: none; }
    .data-table td strong { color: var(--text-primary); font-weight: 600; }

    /* 공용 컴포넌트 */
    .status-badge {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        background: #e8f3ff;
        color: var(--point-color);
    }

    .channel-kakao {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        background: #FEE500;
        color: #191919;
    }

    .action-button {
        padding: 10px 16px;
        background-color: #f2f4f6;
        color: var(--text-secondary);
        font-size: 14px;
        font-weight: 600;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        white-space: nowrap;
    }

    .text-link-btn {
        background: none; border: none;
        color: var(--point-color);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
    }

    .th-list th {
        text-align: center;
        padding: 12px 8px;
        color: #4E5968;
        font-size: 14px;
    }

    .tr-list td {
        text-align: center;
    }

    .request {
        background-color: #f2f4f6;
        color: #4e5968;
    }

    .detail {
        background-color: #E8F8EE;
        color: #32C35A;
    }

    .update {
        color: #3182F6;
        background-color: #E8F3FF;
    }

    .delete {
        background-color: #FEECEF;
        color: #F04452;
    }

    .detail:hover {
        background-color: #CEF0D9;
    }

    .update:hover {
        background-color: #D6E8FF;
    }

    .delete:hover {
        background-color: #FCD6DB;
    }


.modal-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 2000;
}

.modal-card {
    background: var(--bg-surface);
    width: 100%;
    max-width: 420px;
    border-radius: 32px;
    padding: 32px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.7);
    animation: modal-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modal-pop {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
}

.modal-header {
    text-align: center;
    margin-bottom: 24px;
}

.modal-header h2 {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.8px;
    margin-bottom: 8px;
}

.modal-header p {
    color: var(--text-tertiary);
    font-size: 14px;
    margin: 0;
}

.modal-data-box {
    background-color: var(--bg-canvas);
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 24px;
}

.data-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
}

.data-row:last-child { margin-bottom: 0; }

.data-label { color: black; font-size: 13px; font-weight: 600; }
.data-value { color: black; font-size: 14px; font-weight: 700; }

.modal-textarea {
    width: 100%;
    height: 130px;
    background: var(--bg-canvas);
    border: 2px solid transparent;
    border-radius: 18px;
    padding: 16px;
    font-size: 15px;
    font-family: inherit;
    resize: none;
    outline: none;
    transition: all 0.2s ease;
    margin-bottom: 24px;
    align-items: center;
}

.modal-textarea:focus {
    background: white;
    border-color: var(--point-color);
    box-shadow: 0 0 0 4px rgba(49, 130, 246, 0.1);
}

.modal-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.btn-confirm {
    width: 100%;
    padding: 18px;
    border-radius: 18px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
}

.btn-blue { background-color: var(--point-color); color: white; }
.btn-blue:hover { background-color: #1b64da; transform: translateY(-2px); }

.btn-red { background-color: #FEECEF; color: #F04452; }
.btn-red:hover { background-color: #FCD6DB; }

.btn-ghost {
    background: none;
    color: var(--text-tertiary);
    font-weight: 600;
    font-size: 14px;
    padding: 12px;
}
.btn-ghost:hover { color: var(--text-secondary); }

</style>
<body>
<nav>
    <div class="nav-brand">Console</div>
    <ul class="nav-menu">
        <li class="nav-item active">📊 대시보드</li>
        <li class="nav-item">
            <a href="/admin/place">🏠 장소/방 관리</a>
        </li>
        <li class="nav-item">🫥 회원 관리</li>
        <li class="nav-item">🧾 결제 내역</li>
        <li class="nav-item">📫 Q&A</li>
        <li class="nav-item">⭐ 리뷰 내역</li>
        <li class="nav-item">🎧 고객 지원</li>
    </ul>
</nav>
<main>
    <header>
        <h1>환불관리</h1>
    </header>

    <div class="content-surface">
        <div class="section-header">
            <h2>최근 환불 내역</h2>
            <button class="text-link-btn">전체보기</button>
        </div>
        <table class="data-table">
            <thead>
            <tr class="th-list">
                <th>환불번호</th>
                <th>환불상태</th>
                <th>방 이름</th>
                <th>이용자</th>
                <th>결제코드</th>
                <th>결제금액</th>
                <th>환불일</th>
                <th>결제경로</th>
                <th>버튼</th>
            </tr>
            </thead>
            {{#refundList}}
            <tbody>
            <tr class="tr-list">
                <td data-id="{{id}}">{{id}}</td>
                <td><span class="status-badge" data-status="{{displayStatus}}">{{displayStatus}}</span></td>
                <td>{{roomName}}</td>
                <td><strong>{{username}}</strong></td>
                <td>{{paymentKey}}</td>
                <td>{{amount}}원</td>
                <td>{{createdAt}}</td>
                <td><span class="channel-kakao">{{paymentMethod}}</span></td>
                <td style="display: flex; justify-content: center; gap: 12px;">
                    <button class="action-button detail approve-btn" data-id="{{id}}">승인</button>
                    <button class="action-button delete rejection-btn" data-id="{{id}}">거절</button>
                    <button class="action-button update detail-btn" data-id="{{id}}">상세보기</button>
                </td>
            </tr>
            </tbody>
            {{/refundList}}
        </table>
    </div>

</main>

<!--  ★ modal ★ -->
<div class="modal-overlay" id="modal-detail">
    <div class="modal-card">
        <div class="modal-header">
            <h2>상세 정보</h2>
            <p>예약 및 환불 내역을 확인합니다</p>
        </div>

        <div class="modal-data-box">
            <div class="data-row">
                <span class="data-label">환불번호</span>
                <span class="data-value" id="refund-id">1</span>
            </div>
            <div class="data-row">
                <span class="data-label">환불상태</span>
                <span class="data-value" id="refund-status">환불요청</span>
            </div>
            <div class="data-row">
                <span class="data-label">공간명</span>
                <span class="data-value" id="refund-room-name">어울림 루프탑 A</span>
            </div>
            <div class="data-row">
                <span class="data-label">사용자</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-user-name"></span>
            </div>
            <div class="data-row">
                <span class="data-label">결제번호</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-payment-key"></span>
            </div>
            <div class="data-row">
                <span class="data-label">결제금액</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-payment-amount"></span>
            </div>
            <div class="data-row">
                <span class="data-label">이용시간</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-display-time"></span>
            </div>
            <div class="data-row">
                <span class="data-label">환불 생성일</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-created-at"></span>
            </div>
            <div class="data-row">
                <span class="data-label">결제경로</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-payment-method"></span>
            </div>
            <div class="data-row">
                <span class="data-label">사용자 환불사유</span>
                <span class="data-value" style="color: var(--point-color);" id="refund-reason"></span>
            </div>
        </div>

        <div class="modal-actions">
            <button class="btn-confirm btn-blue" onclick="closeDetailModal()">확인</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modal-reject" style="margin-top: 50px;">
    <div class="modal-card">
        <div class="modal-header">
            <h2>환불 거절</h2>
            <p>사용자에게 전달할 거절 사유를 적어주세요</p>
        </div>

        <textarea class="modal-textarea" id="admin-reason" placeholder="이유를 입력해주세요 (예: 이용 수칙 위반)"></textarea>

        <div class="modal-actions">
            <button class="btn-confirm btn-red" id="btn-rejection">환불 거절 확정</button>
            <button class="btn-confirm btn-ghost" onclick="closeRejectModal()">돌아가기</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const approveBtn = document.querySelectorAll('.approve-btn');
        const rejectionBtn = document.querySelectorAll('.rejection-btn');
        const detailBtn = document.querySelectorAll('.detail-btn');
        const reasonInput = document.querySelector('.modal-textarea');
        const trList = document.querySelectorAll('.tr-list');

        trList.forEach(tr => {
           const statusBadge = tr.querySelector('.status-badge');
           const status = statusBadge.textContent.trim();

           const approveBtn = tr.querySelector('.approve-btn');
           const rejectionBtn = tr.querySelector('.rejection-btn');

           statusBadge.classList.remove('request', 'detail', 'delete');

           if (status == '환불요청') {
                statusBadge.classList.add('request');
           } else if (status == '환불완료') {
                statusBadge.classList.add('detail');
                if (rejectionBtn) rejectionBtn.style.display = 'none';
                if (approveBtn) approveBtn.style.display = 'none';
           } else {
              statusBadge.classList.add('delete');
              rejectionBtn.style.display = 'none';
              if (rejectionBtn) rejectionBtn.style.display = 'none';
              if (approveBtn) approveBtn.style.display = 'none';
           }
        });

        approveBtn.forEach(btn => {
            btn.addEventListener('click', async() => {
                alert('승인 아이디: ' + btn.dataset.id);

                let id = btn.dataset.id;

                if(!confirm("결제환불 승인 요청을 하시겠습니까?")) {
                    return;
                }

                try {
                    const response = await fetch(`/api/refunds/${id}/approve`, {
                        method: 'POST'
                    });

                    if (response.ok) {
                    alert('환불 처리가 완료되었습니다.');
                    location.reload();

                    } else {
                        const errorMsg = await response.text();
                        alert('실패: ' + errorMsg);
                    }

                } catch(error) {
                    console.error(error);
                    alert("환불을 승인하는 도중 오류가 발생했습니다.");
                }

            });
        });

        rejectionBtn.forEach(btn => {
            btn.addEventListener('click', () => {
                openRejectModal(btn.dataset.id);
            });
        });

        detailBtn.forEach(btn => {
            btn.addEventListener('click', () => {
                openDetailModal(btn.dataset.id);
            });
        });

    });

    function openRejectModal(id) {
        const modal = document.getElementById('modal-reject');
        const reasonInput = document.getElementById('admin-reason');
        const btnConfirm = document.querySelector('#btn-rejection');

        modal.style.display = 'flex';

        btnConfirm.onclick = async () => {
            if (!reasonInput.value || reasonInput.value.trim() === "") {
                alert('거절 사유를 입력해주세요.');
                reasonInput.focus();
                return;
            }

            try {
                const response = await fetch(`/api/refunds/${id}/rejection`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        reason: reasonInput.value
                    })
                });

                if (response.ok) {
                    alert('거절 처리가 완료되었습니다.');
                    location.reload();

                } else {
                    const errorMsg = await response.text();
                    alert('실패: ' + errorMsg);
                }
            } catch (error) {
                console.error(error);
                alert('서버 전송 중 오류가 발생했습니다.');
            }
        };
    }

    function closeRejectModal() {
         const modal = document.getElementById('modal-reject');

         modal.style.display = 'none';
    }

    async function openDetailModal(id) {
            const modal = document.getElementById('modal-detail');
            const statusEl = document.getElementById('refund-status');

            modal.style.display = 'flex';

            try {
                const response = await fetch(`/admin/refunds/${id}/detail`);

                if(!response.ok) {
                    alert('상세 정보를 불러오지 못했습니다.');
                    return;
                }

                const data = await response.json();

                document.getElementById('refund-id').innerText = data.id;
                document.getElementById('refund-status').innerText = data.displayStatus;
                document.getElementById('refund-room-name').innerText = data.roomName;
                document.getElementById('refund-user-name').innerText = data.username;
                document.getElementById('refund-payment-key').innerText = data.paymentKey;
                document.getElementById('refund-payment-amount').innerText = data.amount.toLocaleString();
                document.getElementById('refund-display-time').innerText = data.displayTime;
                document.getElementById('refund-created-at').innerText = data.createdAt;
                document.getElementById('refund-payment-method').innerText = data.paymentMethod;
                document.getElementById('refund-reason').innerText = data.reason;

            } catch(error) {
                console.error(error);
                alert('상세 정보를 불러오는 중 오류가 발생했습니다.');
            }
       }

    function closeDetailModal() {
         const modal = document.getElementById('modal-detail');

         modal.style.display = 'none';
    }



</script>
</body>
</html>
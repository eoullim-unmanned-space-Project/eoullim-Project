<link rel="stylesheet" href="/css/admin/layout/nav.css">
<link rel="stylesheet" href="/css/admin/notice/notice.css">

<div class="admin-layout">
    {{> admin/layout/nav}}

    <main class="admin-main">
        <div class="notice-container">

            <div class="notice-card">
                <h2 style="margin:0 0 12px 0;">공지사항 수정</h2>

                <form class="notice-form" action="/admin/notices/{{notice.id}}/edit" method="post">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <input type="text" name="title" value="{{notice.title}}" placeholder="제목을 입력해주세요.">

                    <textarea name="content" style="min-height:180px;">{{notice.content}}</textarea>

                    <div class="notice-btn-group">
                        <a class="notice-btn notice-btn-secondary" href="/admin/notices/{{notice.id}}">
                            취소
                        </a>
                        <button class="notice-btn notice-btn-primary" type="submit">
                            수정 완료
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </main>
</div>

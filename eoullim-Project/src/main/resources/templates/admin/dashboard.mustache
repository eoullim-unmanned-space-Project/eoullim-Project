<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Management Console - Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<style>
    :root {
        --point-color: #3182f6;
        --bg-canvas: #f2f4f6;
        --bg-surface: #ffffff;
        --text-primary: #191f28;
        --text-secondary: #4e5968;
        --text-tertiary: #8b95a1;
        --line-default: #e5e8eb;
        --positive: #32c35a;
        --negative: #f04452;
    }

    * { box-sizing: border-box; -webkit-font-smoothing: antialiased; }
    body {
        margin: 0; padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Pretendard", sans-serif;
        background-color: var(--bg-canvas);
        color: var(--text-primary);
        display: flex;
        min-height: 100vh;
    }

    nav {
        width: 260px; height: 100vh;
        background: white; padding: 40px 20px;
        position: fixed; border-right: 1px solid var(--line-default);
    }
    .nav-brand { font-size: 22px; font-weight: 800; margin-bottom: 40px; padding-left: 12px; }
    .nav-menu { list-style: none; padding: 0; }
    .nav-item {
        padding: 14px 16px; border-radius: 12px;
        font-weight: 600; color: var(--text-secondary);
        cursor: pointer; margin-bottom: 4px; transition: 0.2s;
    }
    .nav-item.active { background-color: #f9fafb; color: var(--point-color); }

    main { margin-left: 260px; padding: 40px 48px; width: 100%; }
    header { margin-bottom: 32px; }
    header h1 { font-size: 28px; font-weight: 700; margin: 0; }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: var(--bg-surface);
        padding: 24px;
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.01);
    }

    .stat-label { color: var(--text-secondary); font-size: 14px; font-weight: 600; margin-bottom: 8px; }
    .stat-value { font-size: 24px; font-weight: 700; color: var(--text-primary); }
    .stat-change { margin-top: 8px; font-size: 13px; font-weight: 600; }
    .stat-change.up { color: var(--positive); }
    .stat-change.down { color: var(--negative); }

    .todayPercent { color: var(--text-secondary); font-size: 14px; font-weight: 600; margin-bottom: 8px; }
    .todayPercent.up { color: var(--positive); }
    .todayPercent.down { color: var(--negative); }

    .todayCount { color: var(--text-secondary); font-size: 14px; font-weight: 600; margin-bottom: 8px; }

    .todayCount.up { color: var(--positive); }
    .todayCount.down { color: var(--negative); }

    .chart-section {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        margin-bottom: 32px;
    }

    .content-surface {
        background: var(--bg-surface);
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.01);
    }

    .section-header {
        display: flex; justify-content: space-between;
        align-items: center; margin-bottom: 20px;
    }
    .section-header h2 { font-size: 18px; font-weight: 700; margin: 0; }

    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th {
        text-align: left; padding: 12px 16px;
        color: var(--text-tertiary); font-size: 13px;
        border-bottom: 1px solid var(--line-default);
    }
    .data-table td { padding: 16px; font-size: 14px; border-bottom: 1px solid var(--line-subs); }
    .status-badge {
        padding: 4px 8px; border-radius: 6px; font-size: 12px; font-weight: 600;
    }
    .status-active { background: #e8f8ee; color: #32c35a; }

    .quick-menu-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .menu-card {
        background: var(--bg-surface);
        padding: 24px 20px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);
    }

    .menu-card:hover {
        transform: translateY(-5px);
        background-color: #ffffff;
        border-color: var(--line-default);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
    }

    .menu-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .qna-bg { background-color: #e8f3ff; }
    .review-bg { background-color: #fff9e5; }
    .user-bg { background-color: #f2f4f6; }
    .support-bg { background-color: #e8f8ee; }

    .menu-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .menu-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.3px;
    }

    .menu-desc {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-tertiary);
    }

    @media (max-width: 1200px) {
        .quick-menu-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .thead-box>tr>th {
        text-align: center;
    }

    .tr-box>td {
        text-align: center;
    }

    .kakao {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        background: #FEE500;
        color: #191919;
    }

    .paymentBtn {
        border:none;
        background:none;
        color:var(--point-color);
        font-weight:600;
        cursor:pointer;
        color: var(--point-color);
    }
</style>

<body>
<nav>
    <div class="nav-brand">어울림</div>
    <ul class="nav-menu">
        <li class="nav-item active">📊 대시보드</li>
        <li class="nav-item">🏠 장소/방 관리</li>
        <li class="nav-item" onclick="location.href='/admin/users'">🫥 회원 관리</li>
        <li class="nav-item">🧾 결제 내역</li>
        <li class="nav-item">📫 Q&A</li>
        <li class="nav-item">⭐ 리뷰 내역</li>
        <li class="nav-item">🎧 고객 지원</li>
    </ul>
</nav>

<main>
    <header>
        <h1>서비스 현황</h1>
    </header>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">금일 매출액</div>
            <div class="stat-value"></div>
            <div class="todayPercent"></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">신규 예약</div>
            <div class="stat-value count"></div>
            <div class="todayCount"></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">대기 중인 환불</div>
            <div class="stat-value refund-count">5건</div>
            <div class="stat-change down" >처리 필요</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">가입자 수</div>
            <div class="stat-value">{{totalUserComma}}명</div>
            {{#isIncrease}}
            <div class="stat-change up">▲ {{increaseRate}}%</div>
            {{/isIncrease}}
            {{^isIncrease}}
            <div class="stat-change down">▼ {{increaseRate}}%</div>
            {{/isIncrease}}
        </div>
    </div>

    <div class="chart-section">
        <div class="quick-menu-grid">

            <div class="menu-card" onclick="location.href='/admin/qna'">
                <div class="menu-icon qna-bg">📫</div>
                <div class="menu-info">
                    <span class="menu-title">Q&A 관리</span>
                    <span class="menu-desc" id="qnaText">새로운 문의 -건</span>
                </div>
            </div>

            <div class="menu-card" onclick="location.href='/admin/reviews'">
                <div class="menu-icon review-bg">⭐</div>
                <div class="menu-info">
                    <span class="menu-title">리뷰 내역</span>
                    <span class="menu-desc" id="avgRatingText">평균 별점 -</span>
                </div>
            </div>

            <div class="menu-card" onclick="location.href='/admin/users'">
                <div class="menu-icon user-bg">🫥</div>
                <div class="menu-info">
                    <span class="menu-title">회원 관리</span>
                    <span class="menu-desc">누적 회원 {{totalUserK}}</span>
                </div>
            </div>

            <div class="menu-card" onclick="location.href='/admin/support'">
                <div class="menu-icon support-bg">🎧</div>
                <div class="menu-info">
                    <span class="menu-title">고객 지원</span>
                    <span class="menu-desc">긴급 장애 접수</span>
                </div>
            </div>
        </div>
        <div class="content-surface">
            <div class="section-header">
                <h2>환불 카테고리 비중</h2>
            </div>
            <canvas id="pieChart"></canvas>
        </div>
    </div>

    <div class="content-surface">
        <div class="section-header">
            <h2>최근 결제 현황</h2>
            <button class="paymentBtn" onclick="location.href='/admin/payment'">전체보기</button>
        </div>
        <table class="data-table">
            <thead class="thead-box">
            <tr>
                <th>결제번호</th>
                <th>이용자</th>
                <th>장소/방</th>
                <th>결제금액</th>
                <th>결제경로</th>
                <th>결제완료 시간</th>
                <th>결제상태</th>
            </tr>
            </thead>
            <tbody class="table-body">
            </tbody>
        </table>
    </div>
</main>

<script>
    let salesChart;

    document.addEventListener('DOMContentLoaded', () => {
        fetchPaymentList();
        fetchTodaySales();
        fetchTodayBookingCounts()
        fetchRefundStatusInRequests()
        fetchAvgRating();
        fetchQnaCount();

        setInterval(fetchTodaySales, 30000);
        setInterval(fetchTodayBookingCounts, 30000);
        setInterval(fetchRefundStatusInRequests, 30000);
        setInterval(fetchAvgRating, 30000);
        setInterval(fetchQnaCount, 30000);
    });

    async function fetchPaymentList() {
        try {
            const response = await fetch("/api/admin/payments");

            const payments = await response.json();

            renderPaymentList(payments);

        } catch (error) {
            console.error("데이터를 불러오는데 실패했습니다.", error);
            alert("결제 리스트를 불러오지 못했습니다.");
        }
    }

    function renderPaymentList(payments) {
        const tableBodyEl = document.querySelector(".table-body");

        tableBodyEl.innerHTML = '';

        payments.forEach(payment => {
            const amount = payment.amount.toLocaleString();

            const row = document.createElement("tr");
            row.className = "tr-box";
            row.innerHTML = `
                    <td>${payment.paymentKey}</td>
                    <td><strong>${payment.name}</strong></td>
                    <td>${payment.placeName}/${payment.roomName}</td>
                    <td>${amount}</td>
                    <td ><span class="kakao">${payment.paymentMethod}</span></td>
                    <td>${payment.approvedAt}</td>
                    <td><span class="status-badge status-active">${payment.displayStatus}</span></td>
            `
            tableBodyEl.appendChild(row);
        });
    }

    async function fetchTodaySales() {
        const statValueEl = document.querySelector(".stat-value");
        const percentEl = document.querySelector(".todayPercent");

        try {
            const response = await fetch("/api/admin/today-sales");

            const data = await response.json();

            const todaySale = data.todaySales || 0;
            const yesterdaySales = data.yesterDaySales || 0;

            statValueEl.innerText = todaySale.toLocaleString() + '원';

            let percent = 0;

            if (yesterdaySales > 0) {
                percent = ((todaySale - yesterdaySales) / yesterdaySales ) * 100;

                if (percent > 0)  {
                    statValueEl.classList.add('up')
                } else if (percent < 0 ) {
                    statValueEl.classList.add('down');
                }


            } else if (yesterdaySales === 0 && todaySale > 0) {
                statValueEl.classList.add('up');
                percent = 100;
            } else {
                percent = 0;
            }

            const percentText = percent.toFixed(1) + '%';

            percentEl.innerText = percentText;

        } catch (error) {
            console.error("데이터를 불러오는데 실패했습니다.", error);
            alert("금액을 불러오지 못했습니다.");
        }

    }

    async function fetchTodayBookingCounts() {
        const countEl = document.querySelector(".count");
        const todayCountEl = document.querySelector(".todayCount");
        try {
            const response = await fetch("/api/admin/new-bookings");

            console.log(response);

            const data = await response.json();

            let upCount = data.todayCount - data.yesterdayCount;

            countEl.innerText = data.todayCount + '건';

            let rate = 0;

            if (data.yesterdayCount > 0) {
                rate = (upCount / data.yesterdayCount) * 100;
            }

            todayCountEl.classList.remove('up', 'down');

            if (upCount > 0) {

                if (rate === 0) {
                    rate = 100;
                }

                todayCountEl.classList.add('up');
                todayCountEl.innerText = `▲ ${upCount} (${rate.toFixed(1)}%)`;

            } else if (upCount < 0) {
                todayCountEl.classList.add('down');
                todayCountEl.innerText = `▼ ${Math.abs(upCount)} (${Math.abs(rate).toFixed(1)}%)`;
            } else {
                todayCountEl.innerText = '변동 없음 (0건)';
                todayCountEl.style.color = 'gray';
            }

        } catch (error) {
            console.log("데이터를 불러오는데 실패했습니다.", error);
            alert("값을 불러오지 못했습니다.");
        }
    }

    async function fetchRefundStatusInRequests() {
        const refundCountEl = document.querySelector(".refund-count");
        const statChange = document.querySelector(".stat-change ");

        try {
            const response = await fetch("/api/admin/refunds/pending")

            const data = await response.json();

            let refundsCount = data.refundCounts;

            refundCountEl.innerText = refundsCount + "건";

            if (refundsCount == 0) {
                statChange.style.display = 'none';
            } else {
                statChange.style.display = 'down';
            }

        } catch (error) {
            console.error("데이터를 불러오는데 실패했습니다.", error);
            alert("값을 불러오지 못했습니다.");
        }
    }

    async function fetchAvgRating() {
        const el = document.getElementById('avgRatingText');
        if (!el) return;

        try {
            const res = await fetch('/api/admin/reviews/avg-rating');
            if (!res.ok) throw new Error('평균 별점 조회 실패');

            const data = await res.json();
            const avg = Number(data.avgRating || 0);

            el.innerText = `평균 별점 ${avg.toFixed(1)}`;

        } catch (e) {
            console.error(e);
            el.innerText = '평균 별점 -';
        }
    }

    async function fetchQnaCount() {
        const el = document.getElementById('qnaText');
        if (!el) return;

        try {
            const res = await fetch('/api/admin/qna/count');
            if (!res.ok) throw new Error('QnA 수 조회 실패');

            const data = await res.json();
            const n = Number(data.todayCount || 0);

            el.innerText = `새로운 문의 ${n}건`;
        } catch (e) {
            console.error(e);
            el.innerText = '새로운 문의 -건';
        }
    }


</script>
</body>
</html>